{"type":"item.completed","item":{"id":"item_6","type":"mcp_tool_call","server":"codex_apps","tool":"github_fetch_commit","arguments":{"repo_full_name":"BlueRay2/history-production","commit_sha":"e901155"},"result":{"content":[{"type":"text","text":"{\"commit\": {\"sha\": \"e901155b5bb29851d2fcab9fbb86f869c2c756f7\", \"message\": \"task-01(kpi): ADR-0001 + SQLite schema + migrator + tests\\n\\nImplements task-01-adr-and-schema per consensus ship verdict (Round 9).\\n\\n- docs/adr/0001-kpi-dashboard.md \\u2014 ADR locking Flask+Jinja+HTMX+Chart.js+SQLite\\n  stack + data model + sparse-metric discipline per consensus J-03 resolution.\\n- db/migrations/001_init.sql \\u2014 8-table schema per research/codex.md \\u00a72:\\n  schema_migrations, videos, projects, video_project_map, ingestion_runs,\\n  channel_metric_snapshots, video_metric_snapshots, video_retention_points,\\n  git_events. All append-only snapshots use (entity, metric, window, observed_on)\\n  PK. 5 indexes for latest-snapshot reads.\\n- app/db.py \\u2014 connection helper with WAL + PRAGMA foreign_keys=ON. Raw-SQL\\n  migrator with sha256 tamper detection. CLI: migrate | status | connect.\\n- tests/test_migrations.py \\u2014 6 tests: fresh-apply, idempotent re-run, tampered\\n  migration detection, FK enforcement, WAL mode, schema_migrations table shape.\\n  All pass (pytest 8.4.2, Python 3.9.23 via practicum env).\\n- pyproject.toml \\u2014 project scaffolding + pytest dev dep; runtime deps deferred\\n  to subsequent tasks per scope.\\n\\nStatus: task-01 pending \\u2192 in-review-codex (r1).\\n\\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\", \"url\": \"https://api.github.com/repos/BlueRay2/history-production/commits/e901155b5bb29851d2fcab9fbb86f869c2c756f7\", \"html_url\": \"https://github.com/BlueRay2/history-production/commit/e901155b5bb29851d2fcab9fbb86f869c2c756f7\", \"diff\": \"\\n\\n\\n@@ -0,0 +1,134 @@\\n+\\\"\\\"\\\"SQLite connection helper + raw-SQL migrator for KPI dashboard.\\n+\\n+Usage:\\n+    python -m app.db migrate           # apply pending migrations\\n+    python -m app.db status            # show current schema version\\n+    python -m app.db connect           # return connection string for ad-hoc sqlite3 CLI\\n+\\\"\\\"\\\"\\n+\\n+from __future__ import annotations\\n+\\n+import argparse\\n+import hashlib\\n+import os\\n+import sqlite3\\n+import sys\\n+from contextlib import contextmanager\\n+from datetime import datetime, timezone\\n+from pathlib import Path\\n+from typing import Iterator\\n+\\n+_DEFAULT_DB = \\\"/home/aiagent/assistant/state/dashboard-kpi.sqlite\\\"\\n+_MIGRATIONS_DIR = Path(__file__).resolve().parent.parent / \\\"db\\\" / \\\"migrations\\\"\\n+\\n+\\n+def db_path() -> str:\\n+    return os.environ.get(\\\"DASHBOARD_KPI_DB\\\", _DEFAULT_DB)\\n+\\n+\\n+@contextmanager\\n+def connect() -> Iterator[sqlite3.Connection]:\\n+    path = db_path()\\n+    Path(path).parent.mkdir(parents=True, exist_ok=True)\\n+    conn = sqlite3.connect(path, isolation_level=None)\\n+    try:\\n+        conn.execute(\\\"PRAGMA journal_mode=WAL\\\")\\n+        conn.execute(\\\"PRAGMA foreign_keys=ON\\\")\\n+        conn.row_factory = sqlite3.Row\\n+        yield conn\\n+    finally:\\n+        conn.close()\\n+\\n+\\n+def _sha256(text: str) -> str:\\n+    return hashlib.sha256(text.encode(\\\"utf-8\\\")).hexdigest()\\n+\\n+\\n+def _now_iso() -> str:\\n+    return datetime.now(timezone.utc).strftime(\\\"%Y-%m-%dT%H:%M:%SZ\\\")\\n+\\n+\\n+def _ensure_migrations_table(conn: sqlite3.Connection) -> None:\\n+    conn.execute(\\n+        \\\"\\\"\\\"\\n+        CREATE TABLE IF NOT EXISTS schema_migrations (\\n+            version    TEXT PRIMARY KEY,\\n+            applied_at TEXT NOT NULL,\\n+            sha256     TEXT NOT NULL\\n+        )\\n+        \\\"\\\"\\\"\\n+    )\\n+\\n+\\n+def _applied_versions(conn: sqlite3.Connection) -> dict[str, str]:\\n+    _ensure_migrations_table(conn)\\n+    return {r[\\\"version\\\"]: r[\\\"sha256\\\"] for r in conn.execute(\\\"SELECT version, sha256 FROM schema_migrations\\\")}\\n+\\n+\\n+def _discover_migrations(dir_: Path = _MIGRATIONS_DIR) -> list[tuple[str, Path, str]]:\\n+    files = sorted(p for p in dir_.glob(\\\"*.sql\\\"))\\n+    out: list[tuple[str, Path, str]] = []\\n+    for p in files:\\n+        version = p.stem.split(\\\"_\\\", 1)[0]\\n+        out.append((version, p, p.read_text(encoding=\\\"utf-8\\\")))\\n+    return out\\n+\\n+\\n+def migrate() -> int:\\n+    with connect() as conn:\\n+        applied = _applied_versions(conn)\\n+        migrations = _discover_migrations()\\n+        pending = 0\\n+        for version, path, sql in migrations:\\n+            current_sha = _sha256(sql)\\n+            if version in applied:\\n+                if applied[version] != current_sha:\\n+                    raise RuntimeError(\\n+                        f\\\"migration {version} ({path.name}) already applied with different content \\\"\\n+                        f\\\"(stored sha {applied[version]} vs current {current_sha}) \\u2014 refusing to overwrite\\\"\\n+                    )\\n+                continue\\n+            conn.executescript(sql)\\n+            conn.execute(\\n+                \\\"INSERT INTO schema_migrations(version, applied_at, sha256) VALUES (?,?,?)\\\",\\n+                (version, _now_iso(), current_sha),\\n+            )\\n+            pending += 1\\n+            print(f\\\"[migrate] applied {version} ({path.name})\\\", file=sys.stderr)\\n+        if pending == 0:\\n+            print(\\\"[migrate] nothing to apply\\\", file=sys.stderr)\\n+        return pending\\n+\\n+\\n+def status() -> None:\\n+    with connect() as conn:\\n+        applied = _applied_versions(conn)\\n+        print(f\\\"db: {db_path()}\\\")\\n+        print(f\\\"applied migrations: {len(applied)}\\\")\\n+        for v in sorted(applied):\\n+            print(f\\\"  {v}  sha={applied[v][:12]}\\\")\\n+\\n+\\n+def main(argv: list[str] | None = None) -> int:\\n+    parser = argparse.ArgumentParser(description=\\\"KPI dashboard DB helper\\\")\\n+    sub = parser.add_subparsers(dest=\\\"cmd\\\", required=True)\\n+    sub.add_parser(\\\"migrate\\\")\\n+    sub.add_parser(\\\"status\\\")\\n+    sub.add_parser(\\\"connect\\\").add_argument(\\n+        \\\"--print-path\\\", action=\\\"store_true\\\", help=\\\"print db file path and exit\\\"\\n+    )\\n+    args = parser.parse_args(argv)\\n+    if args.cmd == \\\"migrate\\\":\\n+        migrate()\\n+        return 0\\n+    if args.cmd == \\\"status\\\":\\n+        status()\\n+        return 0\\n+    if args.cmd == \\\"connect\\\":\\n+        print(db_path())\\n+        return 0\\n+    return 2\\n+\\n+\\n+if __name__ == \\\"__main__\\\":\\n+    raise SystemExit(main())\\n@@ -0,0 +1,133 @@\\n+-- Migration 001: initial schema for KPI dashboard\\n+-- Source: consensus-dashboard-kpi research/codex.md \\u00a72 + finding J-03 sparse-metric semantics\\n+-- Ship: consensus-dashboard-kpi/verdict-round9.md\\n+-- Applied via: python -m app.db migrate\\n+\\n+BEGIN;\\n+\\n+-- Schema versioning\\n+CREATE TABLE IF NOT EXISTS schema_migrations (\\n+    version    TEXT PRIMARY KEY,\\n+    applied_at TEXT NOT NULL,\\n+    sha256     TEXT NOT NULL\\n+);\\n+\\n+-- YouTube video registry\\n+CREATE TABLE videos (\\n+    video_id      TEXT PRIMARY KEY,\\n+    title         TEXT,\\n+    published_at  TEXT,\\n+    channel_id    TEXT,\\n+    city_slug     TEXT,\\n+    duration_s    INTEGER,\\n+    created_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\\n+    updated_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\\n+);\\n+\\n+-- Git-side project registry (one row per city folder in history-production)\\n+CREATE TABLE projects (\\n+    city_slug         TEXT PRIMARY KEY,\\n+    first_commit_at   TEXT,\\n+    canonical_path    TEXT,\\n+    default_branch    TEXT,\\n+    status            TEXT,\\n+    created_at        TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\\n+);\\n+\\n+-- City <-> video mapping with confidence + manual override\\n+CREATE TABLE video_project_map (\\n+    city_slug       TEXT NOT NULL,\\n+    video_id        TEXT NOT NULL,\\n+    confidence      REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\\n+    mapping_source  TEXT NOT NULL CHECK (mapping_source IN ('auto','manual')),\\n+    active          INTEGER NOT NULL DEFAULT 0 CHECK (active IN (0,1)),\\n+    notes           TEXT,\\n+    created_at      TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\\n+    PRIMARY KEY (city_slug, video_id),\\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug),\\n+    FOREIGN KEY (video_id)  REFERENCES videos(video_id)\\n+);\\n+\\n+-- Every daily ingest run (for quota + failure audit)\\n+CREATE TABLE ingestion_runs (\\n+    run_id        TEXT PRIMARY KEY,\\n+    source        TEXT NOT NULL,\\n+    started_at    TEXT NOT NULL,\\n+    finished_at   TEXT,\\n+    status        TEXT NOT NULL,\\n+    quota_units   INTEGER,\\n+    error_text    TEXT\\n+);\\n+\\n+-- Channel-level metric snapshots (append-only)\\n+CREATE TABLE channel_metric_snapshots (\\n+    metric_key    TEXT NOT NULL,\\n+    grain         TEXT NOT NULL,\\n+    window_start  TEXT NOT NULL,\\n+    window_end    TEXT NOT NULL,\\n+    observed_on   TEXT NOT NULL,\\n+    value_num     REAL,\\n+    run_id        TEXT NOT NULL,\\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\\n+    PRIMARY KEY (metric_key, grain, window_start, window_end, observed_on),\\n+    FOREIGN KEY (run_id) REFERENCES ingestion_runs(run_id)\\n+);\\n+\\n+-- Per-video metric snapshots (append-only)\\n+CREATE TABLE video_metric_snapshots (\\n+    video_id      TEXT NOT NULL,\\n+    metric_key    TEXT NOT NULL,\\n+    grain         TEXT NOT NULL,\\n+    window_start  TEXT NOT NULL,\\n+    window_end    TEXT NOT NULL,\\n+    observed_on   TEXT NOT NULL,\\n+    value_num     REAL,\\n+    run_id        TEXT NOT NULL,\\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\\n+    PRIMARY KEY (video_id, metric_key, grain, window_start, window_end, observed_on),\\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\\n+);\\n+\\n+-- Per-video retention curve points\\n+CREATE TABLE video_retention_points (\\n+    video_id         TEXT NOT NULL,\\n+    observed_on      TEXT NOT NULL,\\n+    elapsed_seconds  REAL NOT NULL,\\n+    retention_pct    REAL,\\n+    run_id           TEXT NOT NULL,\\n+    PRIMARY KEY (video_id, observed_on, elapsed_seconds),\\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\\n+);\\n+\\n+-- Git events (commits interpreted as KPI milestones)\\n+CREATE TABLE git_events (\\n+    commit_sha    TEXT PRIMARY KEY,\\n+    city_slug     TEXT,\\n+    branch_name   TEXT,\\n+    committed_at  TEXT NOT NULL,\\n+    event_type    TEXT NOT NULL,\\n+    event_value   TEXT,\\n+    payload_json  TEXT,\\n+    confidence    REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug)\\n+);\\n+\\n+-- Indexes for latest-snapshot reads\\n+CREATE INDEX idx_channel_metric_latest\\n+    ON channel_metric_snapshots(metric_key, window_end, observed_on DESC);\\n+\\n+CREATE INDEX idx_video_metric_latest\\n+    ON video_metric_snapshots(video_id, metric_key, window_end, observed_on DESC);\\n+\\n+CREATE INDEX idx_git_events_city_type\\n+    ON git_events(city_slug, event_type, committed_at);\\n+\\n+CREATE INDEX idx_vpm_video_active\\n+    ON video_project_map(video_id, active);\\n+\\n+CREATE INDEX idx_vpm_city_active\\n+    ON video_project_map(city_slug, active);\\n+\\n+COMMIT;\\n@@ -0,0 +1,62 @@\\n+# ADR-0001 \\u2014 KPI Dashboard stack & architecture\\n+\\n+**Status:** Accepted\\n+**Date:** 2026-04-21\\n+**Context:** consensus-dashboard-kpi run (9 rounds, 2026-04-21), ship verdict round 9.\\n+**Owner:** \\u042f\\u0440\\u043e\\u0441\\u043b\\u0430\\u0432 (208368262); implementation lead: Claude.\\n+\\n+## Context\\n+\\n+Build a local-hosted KPI dashboard for YouTube channel \\\"Cities Evolution\\\" (UCjLrTC9jdfx6iI5w7SL8LHw, 44 subs, 24 videos). Daily 03:30 GMT+3 refresh via pure-Python YouTube API client + history-production git introspection. Weekly / Monthly tabs. Localhost-only MVP.\\n+\\n+## Decision\\n+\\n+### Stack\\n+- **Backend framework:** Flask + Jinja (minimal, Python-native).\\n+- **Frontend interactivity:** HTMX for server-fragment swaps; no SPA. Small amount of hand-rolled vanilla JS for local widget state \\u2014 **no Alpine.js** (avoids micro-framework soup per consensus round 2).\\n+- **Charts:** Chart.js via CDN.\\n+- **Database:** SQLite with WAL journal mode + `PRAGMA foreign_keys=ON`.\\n+- **DB migrations:** raw SQL files in `db/migrations/NNN_*.sql` applied by `app/db.py migrate` \\u2014 no Alembic overhead at this scale.\\n+- **YouTube ingest:** `google-api-python-client` + `google-auth-oauthlib` \\u2014 **not** claude-headless+MCP (consensus round 1 finding F-08).\\n+- **Python:** 3.11+.\\n+- **Runtime:** home-server miniconda env `practicum` + flask dev server under systemd user unit.\\n+\\n+### Data model (see `db/migrations/001_init.sql`)\\n+- Append-only snapshot pattern with `(entity, metric, window, observed_on)` PK \\u2014 no destructive updates.\\n+- First-class `video_project_map` table with `confidence` + manual-override support.\\n+- `git_events` table records heuristic parse output with confidence scores.\\n+\\n+### Deploy layout\\n+- Code lives in this repo (`history-production`) under branch `kpi`.\\n+- Install script creates symlink `/home/aiagent/assistant/deploys/kpi-dashboard \\u2192 /home/aiagent/assistant/git/history-production`.\\n+- Runtime state (DB, logs) under `/home/aiagent/assistant/state/` and `/home/aiagent/assistant/logs/`.\\n+\\n+### Metric handling (sparse-data discipline)\\n+- Unavailable metrics return NULL in SQL, never 0 (consensus finding J-03).\\n+- Repository API `value_with_reason() -> (value, reason)` where reason \\u2208 {`ok`, `below_privacy_floor`, `channel_too_new`, `no_data_pulled`}.\\n+- UI renders each reason distinctly (`N/A` with tooltip vs raw value).\\n+\\n+## Consequences\\n+\\n+### Positive\\n+- Tests are easy: raw SQL + std-lib sqlite3 has zero ORM magic.\\n+- Deploy is a single symlink + one systemd unit.\\n+- Future LAN / auth migration to FastAPI would touch only `app/main.py` \\u2014 ingest/repo/views stay portable.\\n+\\n+### Negative / accepted trade-offs\\n+- Flask dev server is not production-grade \\u2014 acceptable for localhost single-user MVP; gunicorn/uvicorn migration deferred until LAN access is scoped.\\n+- Raw SQL migrations lack the diff tooling of Alembic \\u2014 acceptable at expected schema volume (\\u226420 migrations before major refactor).\\n+\\n+## Rejected alternatives\\n+\\n+- **Streamlit:** heavy rerun model; poor fit for 10-15 charts; weak auth story.\\n+- **FastAPI+HTMX+Alpine+Chart.js:** over-engineered for this MVP; ~2\\u00d7 build time; framework soup risk.\\n+- **Grafana + SQLite:** wrong fit for heuristic joins + mapping overrides + write-back exception workflow.\\n+- **Evidence.dev:** static-site builder; no live mapping-approval workflow.\\n+- **Datasette:** explorer UI, not a curated dashboard; read-only by design.\\n+\\n+## References\\n+\\n+- Consensus run: `/home/aiagent/assistant/git/consensus-dashboard-kpi/`\\n+- Authoritative verdict: highest-numbered `verdict-roundN.md` in that directory (currently `verdict-round9.md`).\\n+- Task process: [../tz/dashboard-kpi/process.md](../tz/dashboard-kpi/process.md)\\n@@ -17,7 +17,7 @@ Full consensus artefacts (research, debates, findings register, verdicts) are in\\n \\n | ID | File | Scope | Status | Codex review | Gemini review |\\n |---|---|---|---|---|---|\\n-| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `pending` | \\u2014 | \\u2014 |\\n+| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `in-review-codex (r1)` | pending | \\u2014 |\\n | 02 | [task-02-youtube-api-client.md](task-02-youtube-api-client.md) | OAuth install-flow, refresh-token cache in `/home/aiagent/.config/youtube-api/.env` (600), typed client wrapper, vcrpy cassette fixtures | `pending` | \\u2014 | \\u2014 |\\n | 03 | [task-03-append-snapshot-ingest.md](task-03-append-snapshot-ingest.md) | Ingestion runs table, rolling 45-d backfill, append-only writes with `observed_on`, preliminary-flag overwrite logic, first-run 45-d backfill script | `pending` | \\u2014 | \\u2014 |\\n | 04 | [task-04-history-git-parser.md](task-04-history-git-parser.md) | `ingest/history_git.py`, heuristic commit scoring (phase-\\\\d+ / script / final / lock patterns), confidence + evidence columns, golden git fixtures | `pending` | \\u2014 | \\u2014 |\\n@@ -0,0 +1,29 @@\\n+[project]\\n+name = \\\"kpi-dashboard\\\"\\n+version = \\\"0.1.0\\\"\\n+description = \\\"Local-hosted KPI dashboard for YouTube channel Cities Evolution.\\\"\\n+requires-python = \\\">=3.11\\\"\\n+dependencies = [\\n+    # Runtime dependencies land here in subsequent tasks:\\n+    #   task-02: google-api-python-client, google-auth-oauthlib, python-dotenv\\n+    #   task-06: flask, jinja2\\n+    # task-01 introduces only the stdlib-backed db layer + test harness.\\n+]\\n+\\n+[project.optional-dependencies]\\n+dev = [\\n+    \\\"pytest>=8.0,<9\\\",\\n+    \\\"pytest-cov>=5.0,<6\\\",\\n+]\\n+\\n+[tool.pytest.ini_options]\\n+testpaths = [\\\"tests\\\"]\\n+pythonpath = [\\\".\\\"]\\n+addopts = \\\"-ra\\\"\\n+\\n+[build-system]\\n+requires = [\\\"setuptools>=68\\\"]\\n+build-backend = \\\"setuptools.build_meta\\\"\\n+\\n+[tool.setuptools]\\n+packages = [\\\"app\\\"]\\n\\n\\n\\n@@ -0,0 +1,74 @@\\n+\\\"\\\"\\\"Tests for app.db migrator.\\n+\\n+Covers:\\n+  - fresh DB: migrate applies all, returns count.\\n+  - re-run migrate: no-op on fully-applied state.\\n+  - tampered migration (content hash mismatch): errors.\\n+  - PRAGMA foreign_keys=ON is actually enforced by connect().\\n+\\\"\\\"\\\"\\n+\\n+from __future__ import annotations\\n+\\n+import hashlib\\n+import os\\n+import sqlite3\\n+from pathlib import Path\\n+\\n+import pytest\\n+\\n+from app import db as dbmod\\n+\\n+\\n+@pytest.fixture\\n+def fresh_db(tmp_path, monkeypatch):\\n+    db_file = tmp_path / \\\"test.sqlite\\\"\\n+    monkeypatch.setenv(\\\"DASHBOARD_KPI_DB\\\", str(db_file))\\n+    yield db_file\\n+\\n+\\n+def test_migrate_applies_all_on_fresh_db(fresh_db):\\n+    applied = dbmod.migrate()\\n+    assert applied >= 1, \\\"at least migration 001 should apply\\\"\\n+    with dbmod.connect() as conn:\\n+        rows = [r[\\\"version\\\"] for r in conn.execute(\\\"SELECT version FROM schema_migrations ORDER BY version\\\")]\\n+    assert \\\"001\\\" in rows\\n+\\n+\\n+def test_migrate_is_idempotent(fresh_db):\\n+    first = dbmod.migrate()\\n+    second = dbmod.migrate()\\n+    assert second == 0, \\\"second migrate should be no-op\\\"\\n+    assert first >= 1\\n+\\n+\\n+def test_migrate_detects_tampered_migration(fresh_db):\\n+    dbmod.migrate()\\n+    # Simulate tamper: overwrite the stored sha256 with a bogus value.\\n+    with dbmod.connect() as conn:\\n+        conn.execute(\\\"UPDATE schema_migrations SET sha256='deadbeef' WHERE version='001'\\\")\\n+    with pytest.raises(RuntimeError, match=\\\"different content\\\"):\\n+        dbmod.migrate()\\n+\\n+\\n+def test_foreign_keys_enforced(fresh_db):\\n+    dbmod.migrate()\\n+    with dbmod.connect() as conn:\\n+        with pytest.raises(sqlite3.IntegrityError):\\n+            conn.execute(\\n+                \\\"INSERT INTO video_project_map(city_slug, video_id, confidence, mapping_source, active) \\\"\\n+                \\\"VALUES ('ghost', 'nothere', 0.5, 'auto', 0)\\\"\\n+            )\\n+\\n+\\n+def test_wal_mode_enabled(fresh_db):\\n+    dbmod.migrate()\\n+    with dbmod.connect() as conn:\\n+        mode = conn.execute(\\\"PRAGMA journal_mode\\\").fetchone()[0]\\n+    assert mode.lower() == \\\"wal\\\"\\n+\\n+\\n+def test_schema_migrations_table_shape(fresh_db):\\n+    dbmod.migrate()\\n+    with dbmod.connect() as conn:\\n+        cols = {r[\\\"name\\\"] for r in conn.execute(\\\"PRAGMA table_info(schema_migrations)\\\")}\\n+    assert cols == {\\\"version\\\", \\\"applied_at\\\", \\\"sha256\\\"}\", \"files\": [{\"filename\": \"app/__init__.py\", \"patch\": null}, {\"filename\": \"app/__pycache__/__init__.cpython-39.pyc\", \"patch\": null}, {\"filename\": \"app/__pycache__/db.cpython-39.pyc\", \"patch\": null}, {\"filename\": \"app/db.py\", \"patch\": \"@@ -0,0 +1,134 @@\\n+\\\"\\\"\\\"SQLite connection helper + raw-SQL migrator for KPI dashboard.\\n+\\n+Usage:\\n+    python -m app.db migrate           # apply pending migrations\\n+    python -m app.db status            # show current schema version\\n+    python -m app.db connect           # return connection string for ad-hoc sqlite3 CLI\\n+\\\"\\\"\\\"\\n+\\n+from __future__ import annotations\\n+\\n+import argparse\\n+import hashlib\\n+import os\\n+import sqlite3\\n+import sys\\n+from contextlib import contextmanager\\n+from datetime import datetime, timezone\\n+from pathlib import Path\\n+from typing import Iterator\\n+\\n+_DEFAULT_DB = \\\"/home/aiagent/assistant/state/dashboard-kpi.sqlite\\\"\\n+_MIGRATIONS_DIR = Path(__file__).resolve().parent.parent / \\\"db\\\" / \\\"migrations\\\"\\n+\\n+\\n+def db_path() -> str:\\n+    return os.environ.get(\\\"DASHBOARD_KPI_DB\\\", _DEFAULT_DB)\\n+\\n+\\n+@contextmanager\\n+def connect() -> Iterator[sqlite3.Connection]:\\n+    path = db_path()\\n+    Path(path).parent.mkdir(parents=True, exist_ok=True)\\n+    conn = sqlite3.connect(path, isolation_level=None)\\n+    try:\\n+        conn.execute(\\\"PRAGMA journal_mode=WAL\\\")\\n+        conn.execute(\\\"PRAGMA foreign_keys=ON\\\")\\n+        conn.row_factory = sqlite3.Row\\n+        yield conn\\n+    finally:\\n+        conn.close()\\n+\\n+\\n+def _sha256(text: str) -> str:\\n+    return hashlib.sha256(text.encode(\\\"utf-8\\\")).hexdigest()\\n+\\n+\\n+def _now_iso() -> str:\\n+    return datetime.now(timezone.utc).strftime(\\\"%Y-%m-%dT%H:%M:%SZ\\\")\\n+\\n+\\n+def _ensure_migrations_table(conn: sqlite3.Connection) -> None:\\n+    conn.execute(\\n+        \\\"\\\"\\\"\\n+        CREATE TABLE IF NOT EXISTS schema_migrations (\\n+            version    TEXT PRIMARY KEY,\\n+            applied_at TEXT NOT NULL,\\n+            sha256     TEXT NOT NULL\\n+        )\\n+        \\\"\\\"\\\"\\n+    )\\n+\\n+\\n+def _applied_versions(conn: sqlite3.Connection) -> dict[str, str]:\\n+    _ensure_migrations_table(conn)\\n+    return {r[\\\"version\\\"]: r[\\\"sha256\\\"] for r in conn.execute(\\\"SELECT version, sha256 FROM schema_migrations\\\")}\\n+\\n+\\n+def _discover_migrations(dir_: Path = _MIGRATIONS_DIR) -> list[tuple[str, Path, str]]:\\n+    files = sorted(p for p in dir_.glob(\\\"*.sql\\\"))\\n+    out: list[tuple[str, Path, str]] = []\\n+    for p in files:\\n+        version = p.stem.split(\\\"_\\\", 1)[0]\\n+        out.append((version, p, p.read_text(encoding=\\\"utf-8\\\")))\\n+    return out\\n+\\n+\\n+def migrate() -> int:\\n+    with connect() as conn:\\n+        applied = _applied_versions(conn)\\n+        migrations = _discover_migrations()\\n+        pending = 0\\n+        for version, path, sql in migrations:\\n+            current_sha = _sha256(sql)\\n+            if version in applied:\\n+                if applied[version] != current_sha:\\n+                    raise RuntimeError(\\n+                        f\\\"migration {version} ({path.name}) already applied with different content \\\"\\n+                        f\\\"(stored sha {applied[version]} vs current {current_sha}) \\u2014 refusing to overwrite\\\"\\n+                    )\\n+                continue\\n+            conn.executescript(sql)\\n+            conn.execute(\\n+                \\\"INSERT INTO schema_migrations(version, applied_at, sha256) VALUES (?,?,?)\\\",\\n+                (version, _now_iso(), current_sha),\\n+            )\\n+            pending += 1\\n+            print(f\\\"[migrate] applied {version} ({path.name})\\\", file=sys.stderr)\\n+        if pending == 0:\\n+            print(\\\"[migrate] nothing to apply\\\", file=sys.stderr)\\n+        return pending\\n+\\n+\\n+def status() -> None:\\n+    with connect() as conn:\\n+        applied = _applied_versions(conn)\\n+        print(f\\\"db: {db_path()}\\\")\\n+        print(f\\\"applied migrations: {len(applied)}\\\")\\n+        for v in sorted(applied):\\n+            print(f\\\"  {v}  sha={applied[v][:12]}\\\")\\n+\\n+\\n+def main(argv: list[str] | None = None) -> int:\\n+    parser = argparse.ArgumentParser(description=\\\"KPI dashboard DB helper\\\")\\n+    sub = parser.add_subparsers(dest=\\\"cmd\\\", required=True)\\n+    sub.add_parser(\\\"migrate\\\")\\n+    sub.add_parser(\\\"status\\\")\\n+    sub.add_parser(\\\"connect\\\").add_argument(\\n+        \\\"--print-path\\\", action=\\\"store_true\\\", help=\\\"print db file path and exit\\\"\\n+    )\\n+    args = parser.parse_args(argv)\\n+    if args.cmd == \\\"migrate\\\":\\n+        migrate()\\n+        return 0\\n+    if args.cmd == \\\"status\\\":\\n+        status()\\n+        return 0\\n+    if args.cmd == \\\"connect\\\":\\n+        print(db_path())\\n+        return 0\\n+    return 2\\n+\\n+\\n+if __name__ == \\\"__main__\\\":\\n+    raise SystemExit(main())\"}, {\"filename\": \"db/migrations/001_init.sql\", \"patch\": \"@@ -0,0 +1,133 @@\\n+-- Migration 001: initial schema for KPI dashboard\\n+-- Source: consensus-dashboard-kpi research/codex.md \\u00a72 + finding J-03 sparse-metric semantics\\n+-- Ship: consensus-dashboard-kpi/verdict-round9.md\\n+-- Applied via: python -m app.db migrate\\n+\\n+BEGIN;\\n+\\n+-- Schema versioning\\n+CREATE TABLE IF NOT EXISTS schema_migrations (\\n+    version    TEXT PRIMARY KEY,\\n+    applied_at TEXT NOT NULL,\\n+    sha256     TEXT NOT NULL\\n+);\\n+\\n+-- YouTube video registry\\n+CREATE TABLE videos (\\n+    video_id      TEXT PRIMARY KEY,\\n+    title         TEXT,\\n+    published_at  TEXT,\\n+    channel_id    TEXT,\\n+    city_slug     TEXT,\\n+    duration_s    INTEGER,\\n+    created_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\\n+    updated_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\\n+);\\n+\\n+-- Git-side project registry (one row per city folder in history-production)\\n+CREATE TABLE projects (\\n+    city_slug         TEXT PRIMARY KEY,\\n+    first_commit_at   TEXT,\\n+    canonical_path    TEXT,\\n+    default_branch    TEXT,\\n+    status            TEXT,\\n+    created_at        TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\\n+);\\n+\\n+-- City <-> video mapping with confidence + manual override\\n+CREATE TABLE video_project_map (\\n+    city_slug       TEXT NOT NULL,\\n+    video_id        TEXT NOT NULL,\\n+    confidence      REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\\n+    mapping_source  TEXT NOT NULL CHECK (mapping_source IN ('auto','manual')),\\n+    active          INTEGER NOT NULL DEFAULT 0 CHECK (active IN (0,1)),\\n+    notes           TEXT,\\n+    created_at      TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\\n+    PRIMARY KEY (city_slug, video_id),\\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug),\\n+    FOREIGN KEY (video_id)  REFERENCES videos(video_id)\\n+);\\n+\\n+-- Every daily ingest run (for quota + failure audit)\\n+CREATE TABLE ingestion_runs (\\n+    run_id        TEXT PRIMARY KEY,\\n+    source        TEXT NOT NULL,\\n+    started_at    TEXT NOT NULL,\\n+    finished_at   TEXT,\\n+    status        TEXT NOT NULL,\\n+    quota_units   INTEGER,\\n+    error_text    TEXT\\n+);\\n+\\n+-- Channel-level metric snapshots (append-only)\\n+CREATE TABLE channel_metric_snapshots (\\n+    metric_key    TEXT NOT NULL,\\n+    grain         TEXT NOT NULL,\\n+    window_start  TEXT NOT NULL,\\n+    window_end    TEXT NOT NULL,\\n+    observed_on   TEXT NOT NULL,\\n+    value_num     REAL,\\n+    run_id        TEXT NOT NULL,\\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\\n+    PRIMARY KEY (metric_key, grain, window_start, window_end, observed_on),\\n+    FOREIGN KEY (run_id) REFERENCES ingestion_runs(run_id)\\n+);\\n+\\n+-- Per-video metric snapshots (append-only)\\n+CREATE TABLE video_metric_snapshots (\\n+    video_id      TEXT NOT NULL,\\n+    metric_key    TEXT NOT NULL,\\n+    grain         TEXT NOT NULL,\\n+    window_start  TEXT NOT NULL,\\n+    window_end    TEXT NOT NULL,\\n+    observed_on   TEXT NOT NULL,\\n+    value_num     REAL,\\n+    run_id        TEXT NOT NULL,\\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\\n+    PRIMARY KEY (video_id, metric_key, grain, window_start, window_end, observed_on),\\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\\n+);\\n+\\n+-- Per-video retention curve points\\n+CREATE TABLE video_retention_points (\\n+    video_id         TEXT NOT NULL,\\n+    observed_on      TEXT NOT NULL,\\n+    elapsed_seconds  REAL NOT NULL,\\n+    retention_pct    REAL,\\n+    run_id           TEXT NOT NULL,\\n+    PRIMARY KEY (video_id, observed_on, elapsed_seconds),\\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\\n+);\\n+\\n+-- Git events (commits interpreted as KPI milestones)\\n+CREATE TABLE git_events (\\n+    commit_sha    TEXT PRIMARY KEY,\\n+    city_slug     TEXT,\\n+    branch_name   TEXT,\\n+    committed_at  TEXT NOT NULL,\\n+    event_type    TEXT NOT NULL,\\n+    event_value   TEXT,\\n+    payload_json  TEXT,\\n+    confidence    REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug)\\n+);\\n+\\n+-- Indexes for latest-snapshot reads\\n+CREATE INDEX idx_channel_metric_latest\\n+    ON channel_metric_snapshots(metric_key, window_end, observed_on DESC);\\n+\\n+CREATE INDEX idx_video_metric_latest\\n+    ON video_metric_snapshots(video_id, metric_key, window_end, observed_on DESC);\\n+\\n+CREATE INDEX idx_git_events_city_type\\n+    ON git_events(city_slug, event_type, committed_at);\\n+\\n+CREATE INDEX idx_vpm_video_active\\n+    ON video_project_map(video_id, active);\\n+\\n+CREATE INDEX idx_vpm_city_active\\n+    ON video_project_map(city_slug, active);\\n+\\n+COMMIT;\"}, {\"filename\": \"docs/adr/0001-kpi-dashboard.md\", \"patch\": \"@@ -0,0 +1,62 @@\\n+# ADR-0001 \\u2014 KPI Dashboard stack & architecture\\n+\\n+**Status:** Accepted\\n+**Date:** 2026-04-21\\n+**Context:** consensus-dashboard-kpi run (9 rounds, 2026-04-21), ship verdict round 9.\\n+**Owner:** \\u042f\\u0440\\u043e\\u0441\\u043b\\u0430\\u0432 (208368262); implementation lead: Claude.\\n+\\n+## Context\\n+\\n+Build a local-hosted KPI dashboard for YouTube channel \\\"Cities Evolution\\\" (UCjLrTC9jdfx6iI5w7SL8LHw, 44 subs, 24 videos). Daily 03:30 GMT+3 refresh via pure-Python YouTube API client + history-production git introspection. Weekly / Monthly tabs. Localhost-only MVP.\\n+\\n+## Decision\\n+\\n+### Stack\\n+- **Backend framework:** Flask + Jinja (minimal, Python-native).\\n+- **Frontend interactivity:** HTMX for server-fragment swaps; no SPA. Small amount of hand-rolled vanilla JS for local widget state \\u2014 **no Alpine.js** (avoids micro-framework soup per consensus round 2).\\n+- **Charts:** Chart.js via CDN.\\n+- **Database:** SQLite with WAL journal mode + `PRAGMA foreign_keys=ON`.\\n+- **DB migrations:** raw SQL files in `db/migrations/NNN_*.sql` applied by `app/db.py migrate` \\u2014 no Alembic overhead at this scale.\\n+- **YouTube ingest:** `google-api-python-client` + `google-auth-oauthlib` \\u2014 **not** claude-headless+MCP (consensus round 1 finding F-08).\\n+- **Python:** 3.11+.\\n+- **Runtime:** home-server miniconda env `practicum` + flask dev server under systemd user unit.\\n+\\n+### Data model (see `db/migrations/001_init.sql`)\\n+- Append-only snapshot pattern with `(entity, metric, window, observed_on)` PK \\u2014 no destructive updates.\\n+- First-class `video_project_map` table with `confidence` + manual-override support.\\n+- `git_events` table records heuristic parse output with confidence scores.\\n+\\n+### Deploy layout\\n+- Code lives in this repo (`history-production`) under branch `kpi`.\\n+- Install script creates symlink `/home/aiagent/assistant/deploys/kpi-dashboard \\u2192 /home/aiagent/assistant/git/history-production`.\\n+- Runtime state (DB, logs) under `/home/aiagent/assistant/state/` and `/home/aiagent/assistant/logs/`.\\n+\\n+### Metric handling (sparse-data discipline)\\n+- Unavailable metrics return NULL in SQL, never 0 (consensus finding J-03).\\n+- Repository API `value_with_reason() -> (value, reason)` where reason \\u2208 {`ok`, `below_privacy_floor`, `channel_too_new`, `no_data_pulled`}.\\n+- UI renders each reason distinctly (`N/A` with tooltip vs raw value).\\n+\\n+## Consequences\\n+\\n+### Positive\\n+- Tests are easy: raw SQL + std-lib sqlite3 has zero ORM magic.\\n+- Deploy is a single symlink + one systemd unit.\\n+- Future LAN / auth migration to FastAPI would touch only `app/main.py` \\u2014 ingest/repo/views stay portable.\\n+\\n+### Negative / accepted trade-offs\\n+- Flask dev server is not production-grade \\u2014 acceptable for localhost single-user MVP; gunicorn/uvicorn migration deferred until LAN access is scoped.\\n+- Raw SQL migrations lack the diff tooling of Alembic \\u2014 acceptable at expected schema volume (\\u226420 migrations before major refactor).\\n+\\n+## Rejected alternatives\\n+\\n+- **Streamlit:** heavy rerun model; poor fit for 10-15 charts; weak auth story.\\n+- **FastAPI+HTMX+Alpine+Chart.js:** over-engineered for this MVP; ~2\\u00d7 build time; framework soup risk.\\n+- **Grafana + SQLite:** wrong fit for heuristic joins + mapping overrides + write-back exception workflow.\\n+- **Evidence.dev:** static-site builder; no live mapping-approval workflow.\\n+- **Datasette:** explorer UI, not a curated dashboard; read-only by design.\\n+\\n+## References\\n+\\n+- Consensus run: `/home/aiagent/assistant/git/consensus-dashboard-kpi/`\\n+- Authoritative verdict: highest-numbered `verdict-roundN.md` in that directory (currently `verdict-round9.md`).\\n+- Task process: [../tz/dashboard-kpi/process.md](../tz/dashboard-kpi/process.md)\"}, {\"filename\": \"docs/tz/dashboard-kpi/README.md\", \"patch\": \"@@ -17,7 +17,7 @@ Full consensus artefacts (research, debates, findings register, verdicts) are in\\n \\n | ID | File | Scope | Status | Codex review | Gemini review |\\n |---|---|---|---|---|---|\\n-| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `pending` | \\u2014 | \\u2014 |\\n+| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `in-review-codex (r1)` | pending | \\u2014 |\\n | 02 | [task-02-youtube-api-client.md](task-02-youtube-api-client.md) | OAuth install-flow, refresh-token cache in `/home/aiagent/.config/youtube-api/.env` (600), typed client wrapper, vcrpy cassette fixtures | `pending` | \\u2014 | \\u2014 |\\n | 03 | [task-03-append-snapshot-ingest.md](task-03-append-snapshot-ingest.md) | Ingestion runs table, rolling 45-d backfill, append-only writes with `observed_on`, preliminary-flag overwrite logic, first-run 45-d backfill script | `pending` | \\u2014 | \\u2014 |\\n | 04 | [task-04-history-git-parser.md](task-04-history-git-parser.md) | `ingest/history_git.py`, heuristic commit scoring (phase-\\\\d+ / script / final / lock patterns), confidence + evidence columns, golden git fixtures | `pending` | \\u2014 | \\u2014 |\"}, {\"filename\": \"pyproject.toml\", \"patch\": \"@@ -0,0 +1,29 @@\\n+[project]\\n+name = \\\"kpi-dashboard\\\"\\n+version = \\\"0.1.0\\\"\\n+description = \\\"Local-hosted KPI dashboard for YouTube channel Cities Evolution.\\\"\\n+requires-python = \\\">=3.11\\\"\\n+dependencies = [\\n+    # Runtime dependencies land here in subsequent tasks:\\n+    #   task-02: google-api-python-client, google-auth-oauthlib, python-dotenv\\n+    #   task-06: flask, jinja2\\n+    # task-01 introduces only the stdlib-backed db layer + test harness.\\n+]\\n+\\n+[project.optional-dependencies]\\n+dev = [\\n+    \\\"pytest>=8.0,<9\\\",\\n+    \\\"pytest-cov>=5.0,<6\\\",\\n+]\\n+\\n+[tool.pytest.ini_options]\\n+testpaths = [\\\"tests\\\"]\\n+pythonpath = [\\\".\\\"]\\n+addopts = \\\"-ra\\\"\\n+\\n+[build-system]\\n+requires = [\\\"setuptools>=68\\\"]\\n+build-backend = \\\"setuptools.build_meta\\\"\\n+\\n+[tool.setuptools]\\n+packages = [\\\"app\\\"]\"}, {\"filename\": \"tests/__init__.py\", \"patch\": null}, {\"filename\": \"tests/__pycache__/__init__.cpython-39.pyc\", \"patch\": null}, {\"filename\": \"tests/__pycache__/test_migrations.cpython-39-pytest-8.4.2.pyc\", \"patch\": null}, {\"filename\": \"tests/test_migrations.py\", \"patch\": \"@@ -0,0 +1,74 @@\\n+\\\"\\\"\\\"Tests for app.db migrator.\\n+\\n+Covers:\\n+  - fresh DB: migrate applies all, returns count.\\n+  - re-run migrate: no-op on fully-applied state.\\n+  - tampered migration (content hash mismatch): errors.\\n+  - PRAGMA foreign_keys=ON is actually enforced by connect().\\n+\\\"\\\"\\\"\\n+\\n+from __future__ import annotations\\n+\\n+import hashlib\\n+import os\\n+import sqlite3\\n+from pathlib import Path\\n+\\n+import pytest\\n+\\n+from app import db as dbmod\\n+\\n+\\n+@pytest.fixture\\n+def fresh_db(tmp_path, monkeypatch):\\n+    db_file = tmp_path / \\\"test.sqlite\\\"\\n+    monkeypatch.setenv(\\\"DASHBOARD_KPI_DB\\\", str(db_file))\\n+    yield db_file\\n+\\n+\\n+def test_migrate_applies_all_on_fresh_db(fresh_db):\\n+    applied = dbmod.migrate()\\n+    assert applied >= 1, \\\"at least migration 001 should apply\\\"\\n+    with dbmod.connect() as conn:\\n+        rows = [r[\\\"version\\\"] for r in conn.execute(\\\"SELECT version FROM schema_migrations ORDER BY version\\\")]\\n+    assert \\\"001\\\" in rows\\n+\\n+\\n+def test_migrate_is_idempotent(fresh_db):\\n+    first = dbmod.migrate()\\n+    second = dbmod.migrate()\\n+    assert second == 0, \\\"second migrate should be no-op\\\"\\n+    assert first >= 1\\n+\\n+\\n+def test_migrate_detects_tampered_migration(fresh_db):\\n+    dbmod.migrate()\\n+    # Simulate tamper: overwrite the stored sha256 with a bogus value.\\n+    with dbmod.connect() as conn:\\n+        conn.execute(\\\"UPDATE schema_migrations SET sha256='deadbeef' WHERE version='001'\\\")\\n+    with pytest.raises(RuntimeError, match=\\\"different content\\\"):\\n+        dbmod.migrate()\\n+\\n+\\n+def test_foreign_keys_enforced(fresh_db):\\n+    dbmod.migrate()\\n+    with dbmod.connect() as conn:\\n+        with pytest.raises(sqlite3.IntegrityError):\\n+            conn.execute(\\n+                \\\"INSERT INTO video_project_map(city_slug, video_id, confidence, mapping_source, active) \\\"\\n+                \\\"VALUES ('ghost', 'nothere', 0.5, 'auto', 0)\\\"\\n+            )\\n+\\n+\\n+def test_wal_mode_enabled(fresh_db):\\n+    dbmod.migrate()\\n+    with dbmod.connect() as conn:\\n+        mode = conn.execute(\\\"PRAGMA journal_mode\\\").fetchone()[0]\\n+    assert mode.lower() == \\\"wal\\\"\\n+\\n+\\n+def test_schema_migrations_table_shape(fresh_db):\\n+    dbmod.migrate()\\n+    with dbmod.connect() as conn:\\n+        cols = {r[\\\"name\\\"] for r in conn.execute(\\\"PRAGMA table_info(schema_migrations)\\\")}\\n+    assert cols == {\\\"version\\\", \\\"applied_at\\\", \\\"sha256\\\"}\"}], \"repository_full_name\": \"BlueRay2/history-production\", \"comments\": null, \"author\": {\"login\": \"Evander\", \"name\": null, \"email\": null, \"avatar_url\": \"https://avatars.githubusercontent.com/u/1937198?v=4\", \"id\": 1937198}, \"committer\": {\"login\": \"Evander\", \"name\": null, \"email\": null, \"avatar_url\": \"https://avatars.githubusercontent.com/u/1937198?v=4\", \"id\": 1937198}, \"created_at\": \"2026-04-21T18:01:39Z\", \"display_url\": \"https://github.com/BlueRay2/history-production/commit/e901155b5bb29851d2fcab9fbb86f869c2c756f7\", \"display_title\": \"task-01(kpi): ADR-0001 + SQLite schema + migrator + tests\"}, \"url\": \"https://github.com/BlueRay2/history-production/commit/e901155b5bb29851d2fcab9fbb86f869c2c756f7\", \"title\": \"task-01(kpi): ADR-0001 + SQLite schema + migrator + tests\\n\\nImplements task-01-adr-and-schema per consensus ship verdict (Round 9).\\n\\n- docs/adr/0001-kpi-dashboard.md \\u2014 ADR locking Flask+Jinja+HTMX+Chart.js+SQLite\\n  stack + data model + sparse-metric discipline per consensus J-03 resolution.\\n- db/migrations/001_init.sql \\u2014 8-table schema per research/codex.md \\u00a72:\\n  schema_migrations, videos, projects, video_project_map, ingestion_runs,\\n  channel_metric_snapshots, video_metric_snapshots, video_retention_points,\\n  git_events. All append-only snapshots use (entity, metric, window, observed_on)\\n  PK. 5 indexes for latest-snapshot reads.\\n- app/db.py \\u2014 connection helper with WAL + PRAGMA foreign_keys=ON. Raw-SQL\\n  migrator with sha256 tamper detection. CLI: migrate | status | connect.\\n- tests/test_migrations.py \\u2014 6 tests: fresh-apply, idempotent re-run, tampered\\n  migration detection, FK enforcement, WAL mode, schema_migrations table shape.\\n  All pass (pytest 8.4.2, Python 3.9.23 via practicum env).\\n- pyproject.toml \\u2014 project scaffolding + pytest dev dep; runtime deps deferred\\n  to subsequent tasks per scope.\\n\\nStatus: task-01 pending \\u2192 in-review-codex (r1).\\n\\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\", \"diff\": \"\\n\\n\\n@@ -0,0 +1,134 @@\\n+\\\"\\\"\\\"SQLite connection helper + raw-SQL migrator for KPI dashboard.\\n+\\n+Usage:\\n+    python -m app.db migrate           # apply pending migrations\\n+    python -m app.db status            # show current schema version\\n+    python -m app.db connect           # return connection string for ad-hoc sqlite3 CLI\\n+\\\"\\\"\\\"\\n+\\n+from __future__ import annotations\\n+\\n+import argparse\\n+import hashlib\\n+import os\\n+import sqlite3\\n+import sys\\n+from contextlib import contextmanager\\n+from datetime import datetime, timezone\\n+from pathlib import Path\\n+from typing import Iterator\\n+\\n+_DEFAULT_DB = \\\"/home/aiagent/assistant/state/dashboard-kpi.sqlite\\\"\\n+_MIGRATIONS_DIR = Path(__file__).resolve().parent.parent / \\\"db\\\" / \\\"migrations\\\"\\n+\\n+\\n+def db_path() -> str:\\n+    return os.environ.get(\\\"DASHBOARD_KPI_DB\\\", _DEFAULT_DB)\\n+\\n+\\n+@contextmanager\\n+def connect() -> Iterator[sqlite3.Connection]:\\n+    path = db_path()\\n+    Path(path).parent.mkdir(parents=True, exist_ok=True)\\n+    conn = sqlite3.connect(path, isolation_level=None)\\n+    try:\\n+        conn.execute(\\\"PRAGMA journal_mode=WAL\\\")\\n+        conn.execute(\\\"PRAGMA foreign_keys=ON\\\")\\n+        conn.row_factory = sqlite3.Row\\n+        yield conn\\n+    finally:\\n+        conn.close()\\n+\\n+\\n+def _sha256(text: str) -> str:\\n+    return hashlib.sha256(text.encode(\\\"utf-8\\\")).hexdigest()\\n+\\n+\\n+def _now_iso() -> str:\\n+    return datetime.now(timezone.utc).strftime(\\\"%Y-%m-%dT%H:%M:%SZ\\\")\\n+\\n+\\n+def _ensure_migrations_table(conn: sqlite3.Connection) -> None:\\n+    conn.execute(\\n+        \\\"\\\"\\\"\\n+        CREATE TABLE IF NOT EXISTS schema_migrations (\\n+            version    TEXT PRIMARY KEY,\\n+            applied_at TEXT NOT NULL,\\n+            sha256     TEXT NOT NULL\\n+        )\\n+        \\\"\\\"\\\"\\n+    )\\n+\\n+\\n+def _applied_versions(conn: sqlite3.Connection) -> dict[str, str]:\\n+    _ensure_migrations_table(conn)\\n+    return {r[\\\"version\\\"]: r[\\\"sha256\\\"] for r in conn.execute(\\\"SELECT version, sha256 FROM schema_migrations\\\")}\\n+\\n+\\n+def _discover_migrations(dir_: Path = _MIGRATIONS_DIR) -> list[tuple[str, Path, str]]:\\n+    files = sorted(p for p in dir_.glob(\\\"*.sql\\\"))\\n+    out: list[tuple[str, Path, str]] = []\\n+    for p in files:\\n+        version = p.stem.split(\\\"_\\\", 1)[0]\\n+        out.append((version, p, p.read_text(encoding=\\\"utf-8\\\")))\\n+    return out\\n+\\n+\\n+def migrate() -> int:\\n+    with connect() as conn:\\n+        applied = _applied_versions(conn)\\n+        migrations = _discover_migrations()\\n+        pending = 0\\n+        for version, path, sql in migrations:\\n+            current_sha = _sha256(sql)\\n+            if version in applied:\\n+                if applied[version] != current_sha:\\n+                    raise RuntimeError(\\n+                        f\\\"migration {version} ({path.name}) already applied with different content \\\"\\n+                        f\\\"(stored sha {applied[version]} vs current {current_sha}) \\u2014 refusing to overwrite\\\"\\n+                    )\\n+                continue\\n+            conn.executescript(sql)\\n+            conn.execute(\\n+                \\\"INSERT INTO schema_migrations(version, applied_at, sha256) VALUES (?,?,?)\\\",\\n+                (version, _now_iso(), current_sha),\\n+            )\\n+            pending += 1\\n+            print(f\\\"[migrate] applied {version} ({path.name})\\\", file=sys.stderr)\\n+        if pending == 0:\\n+            print(\\\"[migrate] nothing to apply\\\", file=sys.stderr)\\n+        return pending\\n+\\n+\\n+def status() -> None:\\n+    with connect() as conn:\\n+        applied = _applied_versions(conn)\\n+        print(f\\\"db: {db_path()}\\\")\\n+        print(f\\\"applied migrations: {len(applied)}\\\")\\n+        for v in sorted(applied):\\n+            print(f\\\"  {v}  sha={applied[v][:12]}\\\")\\n+\\n+\\n+def main(argv: list[str] | None = None) -> int:\\n+    parser = argparse.ArgumentParser(description=\\\"KPI dashboard DB helper\\\")\\n+    sub = parser.add_subparsers(dest=\\\"cmd\\\", required=True)\\n+    sub.add_parser(\\\"migrate\\\")\\n+    sub.add_parser(\\\"status\\\")\\n+    sub.add_parser(\\\"connect\\\").add_argument(\\n+        \\\"--print-path\\\", action=\\\"store_true\\\", help=\\\"print db file path and exit\\\"\\n+    )\\n+    args = parser.parse_args(argv)\\n+    if args.cmd == \\\"migrate\\\":\\n+        migrate()\\n+        return 0\\n+    if args.cmd == \\\"status\\\":\\n+        status()\\n+        return 0\\n+    if args.cmd == \\\"connect\\\":\\n+        print(db_path())\\n+        return 0\\n+    return 2\\n+\\n+\\n+if __name__ == \\\"__main__\\\":\\n+    raise SystemExit(main())\\n@@ -0,0 +1,133 @@\\n+-- Migration 001: initial schema for KPI dashboard\\n+-- Source: consensus-dashboard-kpi research/codex.md \\u00a72 + finding J-03 sparse-metric semantics\\n+-- Ship: consensus-dashboard-kpi/verdict-round9.md\\n+-- Applied via: python -m app.db migrate\\n+\\n+BEGIN;\\n+\\n+-- Schema versioning\\n+CREATE TABLE IF NOT EXISTS schema_migrations (\\n+    version    TEXT PRIMARY KEY,\\n+    applied_at TEXT NOT NULL,\\n+    sha256     TEXT NOT NULL\\n+);\\n+\\n+-- YouTube video registry\\n+CREATE TABLE videos (\\n+    video_id      TEXT PRIMARY KEY,\\n+    title         TEXT,\\n+    published_at  TEXT,\\n+    channel_id    TEXT,\\n+    city_slug     TEXT,\\n+    duration_s    INTEGER,\\n+    created_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\\n+    updated_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\\n+);\\n+\\n+-- Git-side project registry (one row per city folder in history-production)\\n+CREATE TABLE projects (\\n+    city_slug         TEXT PRIMARY KEY,\\n+    first_commit_at   TEXT,\\n+    canonical_path    TEXT,\\n+    default_branch    TEXT,\\n+    status            TEXT,\\n+    created_at        TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\\n+);\\n+\\n+-- City <-> video mapping with confidence + manual override\\n+CREATE TABLE video_project_map (\\n+    city_slug       TEXT NOT NULL,\\n+    video_id        TEXT NOT NULL,\\n+    confidence      REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\\n+    mapping_source  TEXT NOT NULL CHECK (mapping_source IN ('auto','manual')),\\n+    active          INTEGER NOT NULL DEFAULT 0 CHECK (active IN (0,1)),\\n+    notes           TEXT,\\n+    created_at      TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\\n+    PRIMARY KEY (city_slug, video_id),\\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug),\\n+    FOREIGN KEY (video_id)  REFERENCES videos(video_id)\\n+);\\n+\\n+-- Every daily ingest run (for quota + failure audit)\\n+CREATE TABLE ingestion_runs (\\n+    run_id        TEXT PRIMARY KEY,\\n+    source        TEXT NOT NULL,\\n+    started_at    TEXT NOT NULL,\\n+    finished_at   TEXT,\\n+    status        TEXT NOT NULL,\\n+    quota_units   INTEGER,\\n+    error_text    TEXT\\n+);\\n+\\n+-- Channel-level metric snapshots (append-only)\\n+CREATE TABLE channel_metric_snapshots (\\n+    metric_key    TEXT NOT NULL,\\n+    grain         TEXT NOT NULL,\\n+    window_start  TEXT NOT NULL,\\n+    window_end    TEXT NOT NULL,\\n+    observed_on   TEXT NOT NULL,\\n+    value_num     REAL,\\n+    run_id        TEXT NOT NULL,\\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\\n+    PRIMARY KEY (metric_key, grain, window_start, window_end, observed_on),\\n+    FOREIGN KEY (run_id) REFERENCES ingestion_runs(run_id)\\n+);\\n+\\n+-- Per-video metric snapshots (append-only)\\n+CREATE TABLE video_metric_snapshots (\\n+    video_id      TEXT NOT NULL,\\n+    metric_key    TEXT NOT NULL,\\n+    grain         TEXT NOT NULL,\\n+    window_start  TEXT NOT NULL,\\n+    window_end    TEXT NOT NULL,\\n+    observed_on   TEXT NOT NULL,\\n+    value_num     REAL,\\n+    run_id        TEXT NOT NULL,\\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\\n+    PRIMARY KEY (video_id, metric_key, grain, window_start, window_end, observed_on),\\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\\n+);\\n+\\n+-- Per-video retention curve points\\n+CREATE TABLE video_retention_points (\\n+    video_id         TEXT NOT NULL,\\n+    observed_on      TEXT NOT NULL,\\n+    elapsed_seconds  REAL NOT NULL,\\n+    retention_pct    REAL,\\n+    run_id           TEXT NOT NULL,\\n+    PRIMARY KEY (video_id, observed_on, elapsed_seconds),\\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\\n+);\\n+\\n+-- Git events (commits interpreted as KPI milestones)\\n+CREATE TABLE git_events (\\n+    commit_sha    TEXT PRIMARY KEY,\\n+    city_slug     TEXT,\\n+    branch_name   TEXT,\\n+    committed_at  TEXT NOT NULL,\\n+    event_type    TEXT NOT NULL,\\n+    event_value   TEXT,\\n+    payload_json  TEXT,\\n+    confidence    REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug)\\n+);\\n+\\n+-- Indexes for latest-snapshot reads\\n+CREATE INDEX idx_channel_metric_latest\\n+    ON channel_metric_snapshots(metric_key, window_end, observed_on DESC);\\n+\\n+CREATE INDEX idx_video_metric_latest\\n+    ON video_metric_snapshots(video_id, metric_key, window_end, observed_on DESC);\\n+\\n+CREATE INDEX idx_git_events_city_type\\n+    ON git_events(city_slug, event_type, committed_at);\\n+\\n+CREATE INDEX idx_vpm_video_active\\n+    ON video_project_map(video_id, active);\\n+\\n+CREATE INDEX idx_vpm_city_active\\n+    ON video_project_map(city_slug, active);\\n+\\n+COMMIT;\\n@@ -0,0 +1,62 @@\\n+# ADR-0001 \\u2014 KPI Dashboard stack & architecture\\n+\\n+**Status:** Accepted\\n+**Date:** 2026-04-21\\n+**Context:** consensus-dashboard-kpi run (9 rounds, 2026-04-21), ship verdict round 9.\\n+**Owner:** \\u042f\\u0440\\u043e\\u0441\\u043b\\u0430\\u0432 (208368262); implementation lead: Claude.\\n+\\n+## Context\\n+\\n+Build a local-hosted KPI dashboard for YouTube channel \\\"Cities Evolution\\\" (UCjLrTC9jdfx6iI5w7SL8LHw, 44 subs, 24 videos). Daily 03:30 GMT+3 refresh via pure-Python YouTube API client + history-production git introspection. Weekly / Monthly tabs. Localhost-only MVP.\\n+\\n+## Decision\\n+\\n+### Stack\\n+- **Backend framework:** Flask + Jinja (minimal, Python-native).\\n+- **Frontend interactivity:** HTMX for server-fragment swaps; no SPA. Small amount of hand-rolled vanilla JS for local widget state \\u2014 **no Alpine.js** (avoids micro-framework soup per consensus round 2).\\n+- **Charts:** Chart.js via CDN.\\n+- **Database:** SQLite with WAL journal mode + `PRAGMA foreign_keys=ON`.\\n+- **DB migrations:** raw SQL files in `db/migrations/NNN_*.sql` applied by `app/db.py migrate` \\u2014 no Alembic overhead at this scale.\\n+- **YouTube ingest:** `google-api-python-client` + `google-auth-oauthlib` \\u2014 **not** claude-headless+MCP (consensus round 1 finding F-08).\\n+- **Python:** 3.11+.\\n+- **Runtime:** home-server miniconda env `practicum` + flask dev server under systemd user unit.\\n+\\n+### Data model (see `db/migrations/001_init.sql`)\\n+- Append-only snapshot pattern with `(entity, metric, window, observed_on)` PK \\u2014 no destructive updates.\\n+- First-class `video_project_map` table with `confidence` + manual-override support.\\n+- `git_events` table records heuristic parse output with confidence scores.\\n+\\n+### Deploy layout\\n+- Code lives in this repo (`history-production`) under branch `kpi`.\\n+- Install script creates symlink `/home/aiagent/assistant/deploys/kpi-dashboard \\u2192 /home/aiagent/assistant/git/history-production`.\\n+- Runtime state (DB, logs) under `/home/aiagent/assistant/state/` and `/home/aiagent/assistant/logs/`.\\n+\\n+### Metric handling (sparse-data discipline)\\n+- Unavailable metrics return NULL in SQL, never 0 (consensus finding J-03).\\n+- Repository API `value_with_reason() -> (value, reason)` where reason \\u2208 {`ok`, `below_privacy_floor`, `channel_too_new`, `no_data_pulled`}.\\n+- UI renders each reason distinctly (`N/A` with tooltip vs raw value).\\n+\\n+## Consequences\\n+\\n+### Positive\\n+- Tests are easy: raw SQL + std-lib sqlite3 has zero ORM magic.\\n+- Deploy is a single symlink + one systemd unit.\\n+- Future LAN / auth migration to FastAPI would touch only `app/main.py` \\u2014 ingest/repo/views stay portable.\\n+\\n+### Negative / accepted trade-offs\\n+- Flask dev server is not production-grade \\u2014 acceptable for localhost single-user MVP; gunicorn/uvicorn migration deferred until LAN access is scoped.\\n+- Raw SQL migrations lack the diff tooling of Alembic \\u2014 acceptable at expected schema volume (\\u226420 migrations before major refactor).\\n+\\n+## Rejected alternatives\\n+\\n+- **Streamlit:** heavy rerun model; poor fit for 10-15 charts; weak auth story.\\n+- **FastAPI+HTMX+Alpine+Chart.js:** over-engineered for this MVP; ~2\\u00d7 build time; framework soup risk.\\n+- **Grafana + SQLite:** wrong fit for heuristic joins + mapping overrides + write-back exception workflow.\\n+- **Evidence.dev:** static-site builder; no live mapping-approval workflow.\\n+- **Datasette:** explorer UI, not a curated dashboard; read-only by design.\\n+\\n+## References\\n+\\n+- Consensus run: `/home/aiagent/assistant/git/consensus-dashboard-kpi/`\\n+- Authoritative verdict: highest-numbered `verdict-roundN.md` in that directory (currently `verdict-round9.md`).\\n+- Task process: [../tz/dashboard-kpi/process.md](../tz/dashboard-kpi/process.md)\\n@@ -17,7 +17,7 @@ Full consensus artefacts (research, debates, findings register, verdicts) are in\\n \\n | ID | File | Scope | Status | Codex review | Gemini review |\\n |---|---|---|---|---|---|\\n-| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `pending` | \\u2014 | \\u2014 |\\n+| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `in-review-codex (r1)` | pending | \\u2014 |\\n | 02 | [task-02-youtube-api-client.md](task-02-youtube-api-client.md) | OAuth install-flow, refresh-token cache in `/home/aiagent/.config/youtube-api/.env` (600), typed client wrapper, vcrpy cassette fixtures | `pending` | \\u2014 | \\u2014 |\\n | 03 | [task-03-append-snapshot-ingest.md](task-03-append-snapshot-ingest.md) | Ingestion runs table, rolling 45-d backfill, append-only writes with `observed_on`, preliminary-flag overwrite logic, first-run 45-d backfill script | `pending` | \\u2014 | \\u2014 |\\n | 04 | [task-04-history-git-parser.md](task-04-history-git-parser.md) | `ingest/history_git.py`, heuristic commit scoring (phase-\\\\d+ / script / final / lock patterns), confidence + evidence columns, golden git fixtures | `pending` | \\u2014 | \\u2014 |\\n@@ -0,0 +1,29 @@\\n+[project]\\n+name = \\\"kpi-dashboard\\\"\\n+version = \\\"0.1.0\\\"\\n+description = \\\"Local-hosted KPI dashboard for YouTube channel Cities Evolution.\\\"\\n+requires-python = \\\">=3.11\\\"\\n+dependencies = [\\n+    # Runtime dependencies land here in subsequent tasks:\\n+    #   task-02: google-api-python-client, google-auth-oauthlib, python-dotenv\\n+    #   task-06: flask, jinja2\\n+    # task-01 introduces only the stdlib-backed db layer + test harness.\\n+]\\n+\\n+[project.optional-dependencies]\\n+dev = [\\n+    \\\"pytest>=8.0,<9\\\",\\n+    \\\"pytest-cov>=5.0,<6\\\",\\n+]\\n+\\n+[tool.pytest.ini_options]\\n+testpaths = [\\\"tests\\\"]\\n+pythonpath = [\\\".\\\"]\\n+addopts = \\\"-ra\\\"\\n+\\n+[build-system]\\n+requires = [\\\"setuptools>=68\\\"]\\n+build-backend = \\\"setuptools.build_meta\\\"\\n+\\n+[tool.setuptools]\\n+packages = [\\\"app\\\"]\\n\\n\\n\\n@@ -0,0 +1,74 @@\\n+\\\"\\\"\\\"Tests for app.db migrator.\\n+\\n+Covers:\\n+  - fresh DB: migrate applies all, returns count.\\n+  - re-run migrate: no-op on fully-applied state.\\n+  - tampered migration (content hash mismatch): errors.\\n+  - PRAGMA foreign_keys=ON is actually enforced by connect().\\n+\\\"\\\"\\\"\\n+\\n+from __future__ import annotations\\n+\\n+import hashlib\\n+import os\\n+import sqlite3\\n+from pathlib import Path\\n+\\n+import pytest\\n+\\n+from app import db as dbmod\\n+\\n+\\n+@pytest.fixture\\n+def fresh_db(tmp_path, monkeypatch):\\n+    db_file = tmp_path / \\\"test.sqlite\\\"\\n+    monkeypatch.setenv(\\\"DASHBOARD_KPI_DB\\\", str(db_file))\\n+    yield db_file\\n+\\n+\\n+def test_migrate_applies_all_on_fresh_db(fresh_db):\\n+    applied = dbmod.migrate()\\n+    assert applied >= 1, \\\"at least migration 001 should apply\\\"\\n+    with dbmod.connect() as conn:\\n+        rows = [r[\\\"version\\\"] for r in conn.execute(\\\"SELECT version FROM schema_migrations ORDER BY version\\\")]\\n+    assert \\\"001\\\" in rows\\n+\\n+\\n+def test_migrate_is_idempotent(fresh_db):\\n+    first = dbmod.migrate()\\n+    second = dbmod.migrate()\\n+    assert second == 0, \\\"second migrate should be no-op\\\"\\n+    assert first >= 1\\n+\\n+\\n+def test_migrate_detects_tampered_migration(fresh_db):\\n+    dbmod.migrate()\\n+    # Simulate tamper: overwrite the stored sha256 with a bogus value.\\n+    with dbmod.connect() as conn:\\n+        conn.execute(\\\"UPDATE schema_migrations SET sha256='deadbeef' WHERE version='001'\\\")\\n+    with pytest.raises(RuntimeError, match=\\\"different content\\\"):\\n+        dbmod.migrate()\\n+\\n+\\n+def test_foreign_keys_enforced(fresh_db):\\n+    dbmod.migrate()\\n+    with dbmod.connect() as conn:\\n+        with pytest.raises(sqlite3.IntegrityError):\\n+            conn.execute(\\n+                \\\"INSERT INTO video_project_map(city_slug, video_id, confidence, mapping_source, active) \\\"\\n+                \\\"VALUES ('ghost', 'nothere', 0.5, 'auto', 0)\\\"\\n+            )\\n+\\n+\\n+def test_wal_mode_enabled(fresh_db):\\n+    dbmod.migrate()\\n+    with dbmod.connect() as conn:\\n+        mode = conn.execute(\\\"PRAGMA journal_mode\\\").fetchone()[0]\\n+    assert mode.lower() == \\\"wal\\\"\\n+\\n+\\n+def test_schema_migrations_table_shape(fresh_db):\\n+    dbmod.migrate()\\n+    with dbmod.connect() as conn:\\n+        cols = {r[\\\"name\\\"] for r in conn.execute(\\\"PRAGMA table_info(schema_migrations)\\\")}\\n+    assert cols == {\\\"version\\\", \\\"applied_at\\\", \\\"sha256\\\"}\", \"display_url\": \"https://github.com/BlueRay2/history-production/commit/e901155b5bb29851d2fcab9fbb86f869c2c756f7\", \"display_title\": \"task-01(kpi): ADR-0001 + SQLite schema + migrator + tests\\n\\nImplements task-01-adr-and-schema per consensus ship verdict (Round 9).\\n\\n- docs/adr/0001-kpi-dashboard.md \\u2014 ADR locking Flask+Jinja+HTMX+Chart.js+SQLite\\n  stack + data model + sparse-metric discipline per consensus J-03 resolution.\\n- db/migrations/001_init.sql \\u2014 8-table schema per research/codex.md \\u00a72:\\n  schema_migrations, videos, projects, video_project_map, ingestion_runs,\\n  channel_metric_snapshots, video_metric_snapshots, video_retention_points,\\n  git_events. All append-only snapshots use (entity, metric, window, observed_on)\\n  PK. 5 indexes for latest-snapshot reads.\\n- app/db.py \\u2014 connection helper with WAL + PRAGMA foreign_keys=ON. Raw-SQL\\n  migrator with sha256 tamper detection. CLI: migrate | status | connect.\\n- tests/test_migrations.py \\u2014 6 tests: fresh-apply, idempotent re-run, tampered\\n  migration detection, FK enforcement, WAL mode, schema_migrations table shape.\\n  All pass (pytest 8.4.2, Python 3.9.23 via practicum env).\\n- pyproject.toml \\u2014 project scaffolding + pytest dev dep; runtime deps deferred\\n  to subsequent tasks per scope.\\n\\nStatus: task-01 pending \\u2192 in-review-codex (r1).\\n\\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\"}"}],"structured_content":{"commit":{"sha":"e901155b5bb29851d2fcab9fbb86f869c2c756f7","message":"task-01(kpi): ADR-0001 + SQLite schema + migrator + tests\n\nImplements task-01-adr-and-schema per consensus ship verdict (Round 9).\n\n- docs/adr/0001-kpi-dashboard.md — ADR locking Flask+Jinja+HTMX+Chart.js+SQLite\n  stack + data model + sparse-metric discipline per consensus J-03 resolution.\n- db/migrations/001_init.sql — 8-table schema per research/codex.md §2:\n  schema_migrations, videos, projects, video_project_map, ingestion_runs,\n  channel_metric_snapshots, video_metric_snapshots, video_retention_points,\n  git_events. All append-only snapshots use (entity, metric, window, observed_on)\n  PK. 5 indexes for latest-snapshot reads.\n- app/db.py — connection helper with WAL + PRAGMA foreign_keys=ON. Raw-SQL\n  migrator with sha256 tamper detection. CLI: migrate | status | connect.\n- tests/test_migrations.py — 6 tests: fresh-apply, idempotent re-run, tampered\n  migration detection, FK enforcement, WAL mode, schema_migrations table shape.\n  All pass (pytest 8.4.2, Python 3.9.23 via practicum env).\n- pyproject.toml — project scaffolding + pytest dev dep; runtime deps deferred\n  to subsequent tasks per scope.\n\nStatus: task-01 pending → in-review-codex (r1).\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>","url":"https://api.github.com/repos/BlueRay2/history-production/commits/e901155b5bb29851d2fcab9fbb86f869c2c756f7","html_url":"https://github.com/BlueRay2/history-production/commit/e901155b5bb29851d2fcab9fbb86f869c2c756f7","diff":"\n\n\n@@ -0,0 +1,134 @@\n+\"\"\"SQLite connection helper + raw-SQL migrator for KPI dashboard.\n+\n+Usage:\n+    python -m app.db migrate           # apply pending migrations\n+    python -m app.db status            # show current schema version\n+    python -m app.db connect           # return connection string for ad-hoc sqlite3 CLI\n+\"\"\"\n+\n+from __future__ import annotations\n+\n+import argparse\n+import hashlib\n+import os\n+import sqlite3\n+import sys\n+from contextlib import contextmanager\n+from datetime import datetime, timezone\n+from pathlib import Path\n+from typing import Iterator\n+\n+_DEFAULT_DB = \"/home/aiagent/assistant/state/dashboard-kpi.sqlite\"\n+_MIGRATIONS_DIR = Path(__file__).resolve().parent.parent / \"db\" / \"migrations\"\n+\n+\n+def db_path() -> str:\n+    return os.environ.get(\"DASHBOARD_KPI_DB\", _DEFAULT_DB)\n+\n+\n+@contextmanager\n+def connect() -> Iterator[sqlite3.Connection]:\n+    path = db_path()\n+    Path(path).parent.mkdir(parents=True, exist_ok=True)\n+    conn = sqlite3.connect(path, isolation_level=None)\n+    try:\n+        conn.execute(\"PRAGMA journal_mode=WAL\")\n+        conn.execute(\"PRAGMA foreign_keys=ON\")\n+        conn.row_factory = sqlite3.Row\n+        yield conn\n+    finally:\n+        conn.close()\n+\n+\n+def _sha256(text: str) -> str:\n+    return hashlib.sha256(text.encode(\"utf-8\")).hexdigest()\n+\n+\n+def _now_iso() -> str:\n+    return datetime.now(timezone.utc).strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n+\n+\n+def _ensure_migrations_table(conn: sqlite3.Connection) -> None:\n+    conn.execute(\n+        \"\"\"\n+        CREATE TABLE IF NOT EXISTS schema_migrations (\n+            version    TEXT PRIMARY KEY,\n+            applied_at TEXT NOT NULL,\n+            sha256     TEXT NOT NULL\n+        )\n+        \"\"\"\n+    )\n+\n+\n+def _applied_versions(conn: sqlite3.Connection) -> dict[str, str]:\n+    _ensure_migrations_table(conn)\n+    return {r[\"version\"]: r[\"sha256\"] for r in conn.execute(\"SELECT version, sha256 FROM schema_migrations\")}\n+\n+\n+def _discover_migrations(dir_: Path = _MIGRATIONS_DIR) -> list[tuple[str, Path, str]]:\n+    files = sorted(p for p in dir_.glob(\"*.sql\"))\n+    out: list[tuple[str, Path, str]] = []\n+    for p in files:\n+        version = p.stem.split(\"_\", 1)[0]\n+        out.append((version, p, p.read_text(encoding=\"utf-8\")))\n+    return out\n+\n+\n+def migrate() -> int:\n+    with connect() as conn:\n+        applied = _applied_versions(conn)\n+        migrations = _discover_migrations()\n+        pending = 0\n+        for version, path, sql in migrations:\n+            current_sha = _sha256(sql)\n+            if version in applied:\n+                if applied[version] != current_sha:\n+                    raise RuntimeError(\n+                        f\"migration {version} ({path.name}) already applied with different content \"\n+                        f\"(stored sha {applied[version]} vs current {current_sha}) — refusing to overwrite\"\n+                    )\n+                continue\n+            conn.executescript(sql)\n+            conn.execute(\n+                \"INSERT INTO schema_migrations(version, applied_at, sha256) VALUES (?,?,?)\",\n+                (version, _now_iso(), current_sha),\n+            )\n+            pending += 1\n+            print(f\"[migrate] applied {version} ({path.name})\", file=sys.stderr)\n+        if pending == 0:\n+            print(\"[migrate] nothing to apply\", file=sys.stderr)\n+        return pending\n+\n+\n+def status() -> None:\n+    with connect() as conn:\n+        applied = _applied_versions(conn)\n+        print(f\"db: {db_path()}\")\n+        print(f\"applied migrations: {len(applied)}\")\n+        for v in sorted(applied):\n+            print(f\"  {v}  sha={applied[v][:12]}\")\n+\n+\n+def main(argv: list[str] | None = None) -> int:\n+    parser = argparse.ArgumentParser(description=\"KPI dashboard DB helper\")\n+    sub = parser.add_subparsers(dest=\"cmd\", required=True)\n+    sub.add_parser(\"migrate\")\n+    sub.add_parser(\"status\")\n+    sub.add_parser(\"connect\").add_argument(\n+        \"--print-path\", action=\"store_true\", help=\"print db file path and exit\"\n+    )\n+    args = parser.parse_args(argv)\n+    if args.cmd == \"migrate\":\n+        migrate()\n+        return 0\n+    if args.cmd == \"status\":\n+        status()\n+        return 0\n+    if args.cmd == \"connect\":\n+        print(db_path())\n+        return 0\n+    return 2\n+\n+\n+if __name__ == \"__main__\":\n+    raise SystemExit(main())\n@@ -0,0 +1,133 @@\n+-- Migration 001: initial schema for KPI dashboard\n+-- Source: consensus-dashboard-kpi research/codex.md §2 + finding J-03 sparse-metric semantics\n+-- Ship: consensus-dashboard-kpi/verdict-round9.md\n+-- Applied via: python -m app.db migrate\n+\n+BEGIN;\n+\n+-- Schema versioning\n+CREATE TABLE IF NOT EXISTS schema_migrations (\n+    version    TEXT PRIMARY KEY,\n+    applied_at TEXT NOT NULL,\n+    sha256     TEXT NOT NULL\n+);\n+\n+-- YouTube video registry\n+CREATE TABLE videos (\n+    video_id      TEXT PRIMARY KEY,\n+    title         TEXT,\n+    published_at  TEXT,\n+    channel_id    TEXT,\n+    city_slug     TEXT,\n+    duration_s    INTEGER,\n+    created_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n+    updated_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\n+);\n+\n+-- Git-side project registry (one row per city folder in history-production)\n+CREATE TABLE projects (\n+    city_slug         TEXT PRIMARY KEY,\n+    first_commit_at   TEXT,\n+    canonical_path    TEXT,\n+    default_branch    TEXT,\n+    status            TEXT,\n+    created_at        TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\n+);\n+\n+-- City <-> video mapping with confidence + manual override\n+CREATE TABLE video_project_map (\n+    city_slug       TEXT NOT NULL,\n+    video_id        TEXT NOT NULL,\n+    confidence      REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\n+    mapping_source  TEXT NOT NULL CHECK (mapping_source IN ('auto','manual')),\n+    active          INTEGER NOT NULL DEFAULT 0 CHECK (active IN (0,1)),\n+    notes           TEXT,\n+    created_at      TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n+    PRIMARY KEY (city_slug, video_id),\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug),\n+    FOREIGN KEY (video_id)  REFERENCES videos(video_id)\n+);\n+\n+-- Every daily ingest run (for quota + failure audit)\n+CREATE TABLE ingestion_runs (\n+    run_id        TEXT PRIMARY KEY,\n+    source        TEXT NOT NULL,\n+    started_at    TEXT NOT NULL,\n+    finished_at   TEXT,\n+    status        TEXT NOT NULL,\n+    quota_units   INTEGER,\n+    error_text    TEXT\n+);\n+\n+-- Channel-level metric snapshots (append-only)\n+CREATE TABLE channel_metric_snapshots (\n+    metric_key    TEXT NOT NULL,\n+    grain         TEXT NOT NULL,\n+    window_start  TEXT NOT NULL,\n+    window_end    TEXT NOT NULL,\n+    observed_on   TEXT NOT NULL,\n+    value_num     REAL,\n+    run_id        TEXT NOT NULL,\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\n+    PRIMARY KEY (metric_key, grain, window_start, window_end, observed_on),\n+    FOREIGN KEY (run_id) REFERENCES ingestion_runs(run_id)\n+);\n+\n+-- Per-video metric snapshots (append-only)\n+CREATE TABLE video_metric_snapshots (\n+    video_id      TEXT NOT NULL,\n+    metric_key    TEXT NOT NULL,\n+    grain         TEXT NOT NULL,\n+    window_start  TEXT NOT NULL,\n+    window_end    TEXT NOT NULL,\n+    observed_on   TEXT NOT NULL,\n+    value_num     REAL,\n+    run_id        TEXT NOT NULL,\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\n+    PRIMARY KEY (video_id, metric_key, grain, window_start, window_end, observed_on),\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\n+);\n+\n+-- Per-video retention curve points\n+CREATE TABLE video_retention_points (\n+    video_id         TEXT NOT NULL,\n+    observed_on      TEXT NOT NULL,\n+    elapsed_seconds  REAL NOT NULL,\n+    retention_pct    REAL,\n+    run_id           TEXT NOT NULL,\n+    PRIMARY KEY (video_id, observed_on, elapsed_seconds),\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\n+);\n+\n+-- Git events (commits interpreted as KPI milestones)\n+CREATE TABLE git_events (\n+    commit_sha    TEXT PRIMARY KEY,\n+    city_slug     TEXT,\n+    branch_name   TEXT,\n+    committed_at  TEXT NOT NULL,\n+    event_type    TEXT NOT NULL,\n+    event_value   TEXT,\n+    payload_json  TEXT,\n+    confidence    REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug)\n+);\n+\n+-- Indexes for latest-snapshot reads\n+CREATE INDEX idx_channel_metric_latest\n+    ON channel_metric_snapshots(metric_key, window_end, observed_on DESC);\n+\n+CREATE INDEX idx_video_metric_latest\n+    ON video_metric_snapshots(video_id, metric_key, window_end, observed_on DESC);\n+\n+CREATE INDEX idx_git_events_city_type\n+    ON git_events(city_slug, event_type, committed_at);\n+\n+CREATE INDEX idx_vpm_video_active\n+    ON video_project_map(video_id, active);\n+\n+CREATE INDEX idx_vpm_city_active\n+    ON video_project_map(city_slug, active);\n+\n+COMMIT;\n@@ -0,0 +1,62 @@\n+# ADR-0001 — KPI Dashboard stack & architecture\n+\n+**Status:** Accepted\n+**Date:** 2026-04-21\n+**Context:** consensus-dashboard-kpi run (9 rounds, 2026-04-21), ship verdict round 9.\n+**Owner:** Ярослав (208368262); implementation lead: Claude.\n+\n+## Context\n+\n+Build a local-hosted KPI dashboard for YouTube channel \"Cities Evolution\" (UCjLrTC9jdfx6iI5w7SL8LHw, 44 subs, 24 videos). Daily 03:30 GMT+3 refresh via pure-Python YouTube API client + history-production git introspection. Weekly / Monthly tabs. Localhost-only MVP.\n+\n+## Decision\n+\n+### Stack\n+- **Backend framework:** Flask + Jinja (minimal, Python-native).\n+- **Frontend interactivity:** HTMX for server-fragment swaps; no SPA. Small amount of hand-rolled vanilla JS for local widget state — **no Alpine.js** (avoids micro-framework soup per consensus round 2).\n+- **Charts:** Chart.js via CDN.\n+- **Database:** SQLite with WAL journal mode + `PRAGMA foreign_keys=ON`.\n+- **DB migrations:** raw SQL files in `db/migrations/NNN_*.sql` applied by `app/db.py migrate` — no Alembic overhead at this scale.\n+- **YouTube ingest:** `google-api-python-client` + `google-auth-oauthlib` — **not** claude-headless+MCP (consensus round 1 finding F-08).\n+- **Python:** 3.11+.\n+- **Runtime:** home-server miniconda env `practicum` + flask dev server under systemd user unit.\n+\n+### Data model (see `db/migrations/001_init.sql`)\n+- Append-only snapshot pattern with `(entity, metric, window, observed_on)` PK — no destructive updates.\n+- First-class `video_project_map` table with `confidence` + manual-override support.\n+- `git_events` table records heuristic parse output with confidence scores.\n+\n+### Deploy layout\n+- Code lives in this repo (`history-production`) under branch `kpi`.\n+- Install script creates symlink `/home/aiagent/assistant/deploys/kpi-dashboard → /home/aiagent/assistant/git/history-production`.\n+- Runtime state (DB, logs) under `/home/aiagent/assistant/state/` and `/home/aiagent/assistant/logs/`.\n+\n+### Metric handling (sparse-data discipline)\n+- Unavailable metrics return NULL in SQL, never 0 (consensus finding J-03).\n+- Repository API `value_with_reason() -> (value, reason)` where reason ∈ {`ok`, `below_privacy_floor`, `channel_too_new`, `no_data_pulled`}.\n+- UI renders each reason distinctly (`N/A` with tooltip vs raw value).\n+\n+## Consequences\n+\n+### Positive\n+- Tests are easy: raw SQL + std-lib sqlite3 has zero ORM magic.\n+- Deploy is a single symlink + one systemd unit.\n+- Future LAN / auth migration to FastAPI would touch only `app/main.py` — ingest/repo/views stay portable.\n+\n+### Negative / accepted trade-offs\n+- Flask dev server is not production-grade — acceptable for localhost single-user MVP; gunicorn/uvicorn migration deferred until LAN access is scoped.\n+- Raw SQL migrations lack the diff tooling of Alembic — acceptable at expected schema volume (≤20 migrations before major refactor).\n+\n+## Rejected alternatives\n+\n+- **Streamlit:** heavy rerun model; poor fit for 10-15 charts; weak auth story.\n+- **FastAPI+HTMX+Alpine+Chart.js:** over-engineered for this MVP; ~2× build time; framework soup risk.\n+- **Grafana + SQLite:** wrong fit for heuristic joins + mapping overrides + write-back exception workflow.\n+- **Evidence.dev:** static-site builder; no live mapping-approval workflow.\n+- **Datasette:** explorer UI, not a curated dashboard; read-only by design.\n+\n+## References\n+\n+- Consensus run: `/home/aiagent/assistant/git/consensus-dashboard-kpi/`\n+- Authoritative verdict: highest-numbered `verdict-roundN.md` in that directory (currently `verdict-round9.md`).\n+- Task process: [../tz/dashboard-kpi/process.md](../tz/dashboard-kpi/process.md)\n@@ -17,7 +17,7 @@ Full consensus artefacts (research, debates, findings register, verdicts) are in\n \n | ID | File | Scope | Status | Codex review | Gemini review |\n |---|---|---|---|---|---|\n-| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `pending` | — | — |\n+| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `in-review-codex (r1)` | pending | — |\n | 02 | [task-02-youtube-api-client.md](task-02-youtube-api-client.md) | OAuth install-flow, refresh-token cache in `/home/aiagent/.config/youtube-api/.env` (600), typed client wrapper, vcrpy cassette fixtures | `pending` | — | — |\n | 03 | [task-03-append-snapshot-ingest.md](task-03-append-snapshot-ingest.md) | Ingestion runs table, rolling 45-d backfill, append-only writes with `observed_on`, preliminary-flag overwrite logic, first-run 45-d backfill script | `pending` | — | — |\n | 04 | [task-04-history-git-parser.md](task-04-history-git-parser.md) | `ingest/history_git.py`, heuristic commit scoring (phase-\\d+ / script / final / lock patterns), confidence + evidence columns, golden git fixtures | `pending` | — | — |\n@@ -0,0 +1,29 @@\n+[project]\n+name = \"kpi-dashboard\"\n+version = \"0.1.0\"\n+description = \"Local-hosted KPI dashboard for YouTube channel Cities Evolution.\"\n+requires-python = \">=3.11\"\n+dependencies = [\n+    # Runtime dependencies land here in subsequent tasks:\n+    #   task-02: google-api-python-client, google-auth-oauthlib, python-dotenv\n+    #   task-06: flask, jinja2\n+    # task-01 introduces only the stdlib-backed db layer + test harness.\n+]\n+\n+[project.optional-dependencies]\n+dev = [\n+    \"pytest>=8.0,<9\",\n+    \"pytest-cov>=5.0,<6\",\n+]\n+\n+[tool.pytest.ini_options]\n+testpaths = [\"tests\"]\n+pythonpath = [\".\"]\n+addopts = \"-ra\"\n+\n+[build-system]\n+requires = [\"setuptools>=68\"]\n+build-backend = \"setuptools.build_meta\"\n+\n+[tool.setuptools]\n+packages = [\"app\"]\n\n\n\n@@ -0,0 +1,74 @@\n+\"\"\"Tests for app.db migrator.\n+\n+Covers:\n+  - fresh DB: migrate applies all, returns count.\n+  - re-run migrate: no-op on fully-applied state.\n+  - tampered migration (content hash mismatch): errors.\n+  - PRAGMA foreign_keys=ON is actually enforced by connect().\n+\"\"\"\n+\n+from __future__ import annotations\n+\n+import hashlib\n+import os\n+import sqlite3\n+from pathlib import Path\n+\n+import pytest\n+\n+from app import db as dbmod\n+\n+\n+@pytest.fixture\n+def fresh_db(tmp_path, monkeypatch):\n+    db_file = tmp_path / \"test.sqlite\"\n+    monkeypatch.setenv(\"DASHBOARD_KPI_DB\", str(db_file))\n+    yield db_file\n+\n+\n+def test_migrate_applies_all_on_fresh_db(fresh_db):\n+    applied = dbmod.migrate()\n+    assert applied >= 1, \"at least migration 001 should apply\"\n+    with dbmod.connect() as conn:\n+        rows = [r[\"version\"] for r in conn.execute(\"SELECT version FROM schema_migrations ORDER BY version\")]\n+    assert \"001\" in rows\n+\n+\n+def test_migrate_is_idempotent(fresh_db):\n+    first = dbmod.migrate()\n+    second = dbmod.migrate()\n+    assert second == 0, \"second migrate should be no-op\"\n+    assert first >= 1\n+\n+\n+def test_migrate_detects_tampered_migration(fresh_db):\n+    dbmod.migrate()\n+    # Simulate tamper: overwrite the stored sha256 with a bogus value.\n+    with dbmod.connect() as conn:\n+        conn.execute(\"UPDATE schema_migrations SET sha256='deadbeef' WHERE version='001'\")\n+    with pytest.raises(RuntimeError, match=\"different content\"):\n+        dbmod.migrate()\n+\n+\n+def test_foreign_keys_enforced(fresh_db):\n+    dbmod.migrate()\n+    with dbmod.connect() as conn:\n+        with pytest.raises(sqlite3.IntegrityError):\n+            conn.execute(\n+                \"INSERT INTO video_project_map(city_slug, video_id, confidence, mapping_source, active) \"\n+                \"VALUES ('ghost', 'nothere', 0.5, 'auto', 0)\"\n+            )\n+\n+\n+def test_wal_mode_enabled(fresh_db):\n+    dbmod.migrate()\n+    with dbmod.connect() as conn:\n+        mode = conn.execute(\"PRAGMA journal_mode\").fetchone()[0]\n+    assert mode.lower() == \"wal\"\n+\n+\n+def test_schema_migrations_table_shape(fresh_db):\n+    dbmod.migrate()\n+    with dbmod.connect() as conn:\n+        cols = {r[\"name\"] for r in conn.execute(\"PRAGMA table_info(schema_migrations)\")}\n+    assert cols == {\"version\", \"applied_at\", \"sha256\"}","files":[{"filename":"app/__init__.py","patch":null},{"filename":"app/__pycache__/__init__.cpython-39.pyc","patch":null},{"filename":"app/__pycache__/db.cpython-39.pyc","patch":null},{"filename":"app/db.py","patch":"@@ -0,0 +1,134 @@\n+\"\"\"SQLite connection helper + raw-SQL migrator for KPI dashboard.\n+\n+Usage:\n+    python -m app.db migrate           # apply pending migrations\n+    python -m app.db status            # show current schema version\n+    python -m app.db connect           # return connection string for ad-hoc sqlite3 CLI\n+\"\"\"\n+\n+from __future__ import annotations\n+\n+import argparse\n+import hashlib\n+import os\n+import sqlite3\n+import sys\n+from contextlib import contextmanager\n+from datetime import datetime, timezone\n+from pathlib import Path\n+from typing import Iterator\n+\n+_DEFAULT_DB = \"/home/aiagent/assistant/state/dashboard-kpi.sqlite\"\n+_MIGRATIONS_DIR = Path(__file__).resolve().parent.parent / \"db\" / \"migrations\"\n+\n+\n+def db_path() -> str:\n+    return os.environ.get(\"DASHBOARD_KPI_DB\", _DEFAULT_DB)\n+\n+\n+@contextmanager\n+def connect() -> Iterator[sqlite3.Connection]:\n+    path = db_path()\n+    Path(path).parent.mkdir(parents=True, exist_ok=True)\n+    conn = sqlite3.connect(path, isolation_level=None)\n+    try:\n+        conn.execute(\"PRAGMA journal_mode=WAL\")\n+        conn.execute(\"PRAGMA foreign_keys=ON\")\n+        conn.row_factory = sqlite3.Row\n+        yield conn\n+    finally:\n+        conn.close()\n+\n+\n+def _sha256(text: str) -> str:\n+    return hashlib.sha256(text.encode(\"utf-8\")).hexdigest()\n+\n+\n+def _now_iso() -> str:\n+    return datetime.now(timezone.utc).strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n+\n+\n+def _ensure_migrations_table(conn: sqlite3.Connection) -> None:\n+    conn.execute(\n+        \"\"\"\n+        CREATE TABLE IF NOT EXISTS schema_migrations (\n+            version    TEXT PRIMARY KEY,\n+            applied_at TEXT NOT NULL,\n+            sha256     TEXT NOT NULL\n+        )\n+        \"\"\"\n+    )\n+\n+\n+def _applied_versions(conn: sqlite3.Connection) -> dict[str, str]:\n+    _ensure_migrations_table(conn)\n+    return {r[\"version\"]: r[\"sha256\"] for r in conn.execute(\"SELECT version, sha256 FROM schema_migrations\")}\n+\n+\n+def _discover_migrations(dir_: Path = _MIGRATIONS_DIR) -> list[tuple[str, Path, str]]:\n+    files = sorted(p for p in dir_.glob(\"*.sql\"))\n+    out: list[tuple[str, Path, str]] = []\n+    for p in files:\n+        version = p.stem.split(\"_\", 1)[0]\n+        out.append((version, p, p.read_text(encoding=\"utf-8\")))\n+    return out\n+\n+\n+def migrate() -> int:\n+    with connect() as conn:\n+        applied = _applied_versions(conn)\n+        migrations = _discover_migrations()\n+        pending = 0\n+        for version, path, sql in migrations:\n+            current_sha = _sha256(sql)\n+            if version in applied:\n+                if applied[version] != current_sha:\n+                    raise RuntimeError(\n+                        f\"migration {version} ({path.name}) already applied with different content \"\n+                        f\"(stored sha {applied[version]} vs current {current_sha}) — refusing to overwrite\"\n+                    )\n+                continue\n+            conn.executescript(sql)\n+            conn.execute(\n+                \"INSERT INTO schema_migrations(version, applied_at, sha256) VALUES (?,?,?)\",\n+                (version, _now_iso(), current_sha),\n+            )\n+            pending += 1\n+            print(f\"[migrate] applied {version} ({path.name})\", file=sys.stderr)\n+        if pending == 0:\n+            print(\"[migrate] nothing to apply\", file=sys.stderr)\n+        return pending\n+\n+\n+def status() -> None:\n+    with connect() as conn:\n+        applied = _applied_versions(conn)\n+        print(f\"db: {db_path()}\")\n+        print(f\"applied migrations: {len(applied)}\")\n+        for v in sorted(applied):\n+            print(f\"  {v}  sha={applied[v][:12]}\")\n+\n+\n+def main(argv: list[str] | None = None) -> int:\n+    parser = argparse.ArgumentParser(description=\"KPI dashboard DB helper\")\n+    sub = parser.add_subparsers(dest=\"cmd\", required=True)\n+    sub.add_parser(\"migrate\")\n+    sub.add_parser(\"status\")\n+    sub.add_parser(\"connect\").add_argument(\n+        \"--print-path\", action=\"store_true\", help=\"print db file path and exit\"\n+    )\n+    args = parser.parse_args(argv)\n+    if args.cmd == \"migrate\":\n+        migrate()\n+        return 0\n+    if args.cmd == \"status\":\n+        status()\n+        return 0\n+    if args.cmd == \"connect\":\n+        print(db_path())\n+        return 0\n+    return 2\n+\n+\n+if __name__ == \"__main__\":\n+    raise SystemExit(main())"},{"filename":"db/migrations/001_init.sql","patch":"@@ -0,0 +1,133 @@\n+-- Migration 001: initial schema for KPI dashboard\n+-- Source: consensus-dashboard-kpi research/codex.md §2 + finding J-03 sparse-metric semantics\n+-- Ship: consensus-dashboard-kpi/verdict-round9.md\n+-- Applied via: python -m app.db migrate\n+\n+BEGIN;\n+\n+-- Schema versioning\n+CREATE TABLE IF NOT EXISTS schema_migrations (\n+    version    TEXT PRIMARY KEY,\n+    applied_at TEXT NOT NULL,\n+    sha256     TEXT NOT NULL\n+);\n+\n+-- YouTube video registry\n+CREATE TABLE videos (\n+    video_id      TEXT PRIMARY KEY,\n+    title         TEXT,\n+    published_at  TEXT,\n+    channel_id    TEXT,\n+    city_slug     TEXT,\n+    duration_s    INTEGER,\n+    created_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n+    updated_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\n+);\n+\n+-- Git-side project registry (one row per city folder in history-production)\n+CREATE TABLE projects (\n+    city_slug         TEXT PRIMARY KEY,\n+    first_commit_at   TEXT,\n+    canonical_path    TEXT,\n+    default_branch    TEXT,\n+    status            TEXT,\n+    created_at        TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\n+);\n+\n+-- City <-> video mapping with confidence + manual override\n+CREATE TABLE video_project_map (\n+    city_slug       TEXT NOT NULL,\n+    video_id        TEXT NOT NULL,\n+    confidence      REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\n+    mapping_source  TEXT NOT NULL CHECK (mapping_source IN ('auto','manual')),\n+    active          INTEGER NOT NULL DEFAULT 0 CHECK (active IN (0,1)),\n+    notes           TEXT,\n+    created_at      TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n+    PRIMARY KEY (city_slug, video_id),\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug),\n+    FOREIGN KEY (video_id)  REFERENCES videos(video_id)\n+);\n+\n+-- Every daily ingest run (for quota + failure audit)\n+CREATE TABLE ingestion_runs (\n+    run_id        TEXT PRIMARY KEY,\n+    source        TEXT NOT NULL,\n+    started_at    TEXT NOT NULL,\n+    finished_at   TEXT,\n+    status        TEXT NOT NULL,\n+    quota_units   INTEGER,\n+    error_text    TEXT\n+);\n+\n+-- Channel-level metric snapshots (append-only)\n+CREATE TABLE channel_metric_snapshots (\n+    metric_key    TEXT NOT NULL,\n+    grain         TEXT NOT NULL,\n+    window_start  TEXT NOT NULL,\n+    window_end    TEXT NOT NULL,\n+    observed_on   TEXT NOT NULL,\n+    value_num     REAL,\n+    run_id        TEXT NOT NULL,\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\n+    PRIMARY KEY (metric_key, grain, window_start, window_end, observed_on),\n+    FOREIGN KEY (run_id) REFERENCES ingestion_runs(run_id)\n+);\n+\n+-- Per-video metric snapshots (append-only)\n+CREATE TABLE video_metric_snapshots (\n+    video_id      TEXT NOT NULL,\n+    metric_key    TEXT NOT NULL,\n+    grain         TEXT NOT NULL,\n+    window_start  TEXT NOT NULL,\n+    window_end    TEXT NOT NULL,\n+    observed_on   TEXT NOT NULL,\n+    value_num     REAL,\n+    run_id        TEXT NOT NULL,\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\n+    PRIMARY KEY (video_id, metric_key, grain, window_start, window_end, observed_on),\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\n+);\n+\n+-- Per-video retention curve points\n+CREATE TABLE video_retention_points (\n+    video_id         TEXT NOT NULL,\n+    observed_on      TEXT NOT NULL,\n+    elapsed_seconds  REAL NOT NULL,\n+    retention_pct    REAL,\n+    run_id           TEXT NOT NULL,\n+    PRIMARY KEY (video_id, observed_on, elapsed_seconds),\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\n+);\n+\n+-- Git events (commits interpreted as KPI milestones)\n+CREATE TABLE git_events (\n+    commit_sha    TEXT PRIMARY KEY,\n+    city_slug     TEXT,\n+    branch_name   TEXT,\n+    committed_at  TEXT NOT NULL,\n+    event_type    TEXT NOT NULL,\n+    event_value   TEXT,\n+    payload_json  TEXT,\n+    confidence    REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug)\n+);\n+\n+-- Indexes for latest-snapshot reads\n+CREATE INDEX idx_channel_metric_latest\n+    ON channel_metric_snapshots(metric_key, window_end, observed_on DESC);\n+\n+CREATE INDEX idx_video_metric_latest\n+    ON video_metric_snapshots(video_id, metric_key, window_end, observed_on DESC);\n+\n+CREATE INDEX idx_git_events_city_type\n+    ON git_events(city_slug, event_type, committed_at);\n+\n+CREATE INDEX idx_vpm_video_active\n+    ON video_project_map(video_id, active);\n+\n+CREATE INDEX idx_vpm_city_active\n+    ON video_project_map(city_slug, active);\n+\n+COMMIT;"},{"filename":"docs/adr/0001-kpi-dashboard.md","patch":"@@ -0,0 +1,62 @@\n+# ADR-0001 — KPI Dashboard stack & architecture\n+\n+**Status:** Accepted\n+**Date:** 2026-04-21\n+**Context:** consensus-dashboard-kpi run (9 rounds, 2026-04-21), ship verdict round 9.\n+**Owner:** Ярослав (208368262); implementation lead: Claude.\n+\n+## Context\n+\n+Build a local-hosted KPI dashboard for YouTube channel \"Cities Evolution\" (UCjLrTC9jdfx6iI5w7SL8LHw, 44 subs, 24 videos). Daily 03:30 GMT+3 refresh via pure-Python YouTube API client + history-production git introspection. Weekly / Monthly tabs. Localhost-only MVP.\n+\n+## Decision\n+\n+### Stack\n+- **Backend framework:** Flask + Jinja (minimal, Python-native).\n+- **Frontend interactivity:** HTMX for server-fragment swaps; no SPA. Small amount of hand-rolled vanilla JS for local widget state — **no Alpine.js** (avoids micro-framework soup per consensus round 2).\n+- **Charts:** Chart.js via CDN.\n+- **Database:** SQLite with WAL journal mode + `PRAGMA foreign_keys=ON`.\n+- **DB migrations:** raw SQL files in `db/migrations/NNN_*.sql` applied by `app/db.py migrate` — no Alembic overhead at this scale.\n+- **YouTube ingest:** `google-api-python-client` + `google-auth-oauthlib` — **not** claude-headless+MCP (consensus round 1 finding F-08).\n+- **Python:** 3.11+.\n+- **Runtime:** home-server miniconda env `practicum` + flask dev server under systemd user unit.\n+\n+### Data model (see `db/migrations/001_init.sql`)\n+- Append-only snapshot pattern with `(entity, metric, window, observed_on)` PK — no destructive updates.\n+- First-class `video_project_map` table with `confidence` + manual-override support.\n+- `git_events` table records heuristic parse output with confidence scores.\n+\n+### Deploy layout\n+- Code lives in this repo (`history-production`) under branch `kpi`.\n+- Install script creates symlink `/home/aiagent/assistant/deploys/kpi-dashboard → /home/aiagent/assistant/git/history-production`.\n+- Runtime state (DB, logs) under `/home/aiagent/assistant/state/` and `/home/aiagent/assistant/logs/`.\n+\n+### Metric handling (sparse-data discipline)\n+- Unavailable metrics return NULL in SQL, never 0 (consensus finding J-03).\n+- Repository API `value_with_reason() -> (value, reason)` where reason ∈ {`ok`, `below_privacy_floor`, `channel_too_new`, `no_data_pulled`}.\n+- UI renders each reason distinctly (`N/A` with tooltip vs raw value).\n+\n+## Consequences\n+\n+### Positive\n+- Tests are easy: raw SQL + std-lib sqlite3 has zero ORM magic.\n+- Deploy is a single symlink + one systemd unit.\n+- Future LAN / auth migration to FastAPI would touch only `app/main.py` — ingest/repo/views stay portable.\n+\n+### Negative / accepted trade-offs\n+- Flask dev server is not production-grade — acceptable for localhost single-user MVP; gunicorn/uvicorn migration deferred until LAN access is scoped.\n+- Raw SQL migrations lack the diff tooling of Alembic — acceptable at expected schema volume (≤20 migrations before major refactor).\n+\n+## Rejected alternatives\n+\n+- **Streamlit:** heavy rerun model; poor fit for 10-15 charts; weak auth story.\n+- **FastAPI+HTMX+Alpine+Chart.js:** over-engineered for this MVP; ~2× build time; framework soup risk.\n+- **Grafana + SQLite:** wrong fit for heuristic joins + mapping overrides + write-back exception workflow.\n+- **Evidence.dev:** static-site builder; no live mapping-approval workflow.\n+- **Datasette:** explorer UI, not a curated dashboard; read-only by design.\n+\n+## References\n+\n+- Consensus run: `/home/aiagent/assistant/git/consensus-dashboard-kpi/`\n+- Authoritative verdict: highest-numbered `verdict-roundN.md` in that directory (currently `verdict-round9.md`).\n+- Task process: [../tz/dashboard-kpi/process.md](../tz/dashboard-kpi/process.md)"},{"filename":"docs/tz/dashboard-kpi/README.md","patch":"@@ -17,7 +17,7 @@ Full consensus artefacts (research, debates, findings register, verdicts) are in\n \n | ID | File | Scope | Status | Codex review | Gemini review |\n |---|---|---|---|---|---|\n-| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `pending` | — | — |\n+| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `in-review-codex (r1)` | pending | — |\n | 02 | [task-02-youtube-api-client.md](task-02-youtube-api-client.md) | OAuth install-flow, refresh-token cache in `/home/aiagent/.config/youtube-api/.env` (600), typed client wrapper, vcrpy cassette fixtures | `pending` | — | — |\n | 03 | [task-03-append-snapshot-ingest.md](task-03-append-snapshot-ingest.md) | Ingestion runs table, rolling 45-d backfill, append-only writes with `observed_on`, preliminary-flag overwrite logic, first-run 45-d backfill script | `pending` | — | — |\n | 04 | [task-04-history-git-parser.md](task-04-history-git-parser.md) | `ingest/history_git.py`, heuristic commit scoring (phase-\\d+ / script / final / lock patterns), confidence + evidence columns, golden git fixtures | `pending` | — | — |"},{"filename":"pyproject.toml","patch":"@@ -0,0 +1,29 @@\n+[project]\n+name = \"kpi-dashboard\"\n+version = \"0.1.0\"\n+description = \"Local-hosted KPI dashboard for YouTube channel Cities Evolution.\"\n+requires-python = \">=3.11\"\n+dependencies = [\n+    # Runtime dependencies land here in subsequent tasks:\n+    #   task-02: google-api-python-client, google-auth-oauthlib, python-dotenv\n+    #   task-06: flask, jinja2\n+    # task-01 introduces only the stdlib-backed db layer + test harness.\n+]\n+\n+[project.optional-dependencies]\n+dev = [\n+    \"pytest>=8.0,<9\",\n+    \"pytest-cov>=5.0,<6\",\n+]\n+\n+[tool.pytest.ini_options]\n+testpaths = [\"tests\"]\n+pythonpath = [\".\"]\n+addopts = \"-ra\"\n+\n+[build-system]\n+requires = [\"setuptools>=68\"]\n+build-backend = \"setuptools.build_meta\"\n+\n+[tool.setuptools]\n+packages = [\"app\"]"},{"filename":"tests/__init__.py","patch":null},{"filename":"tests/__pycache__/__init__.cpython-39.pyc","patch":null},{"filename":"tests/__pycache__/test_migrations.cpython-39-pytest-8.4.2.pyc","patch":null},{"filename":"tests/test_migrations.py","patch":"@@ -0,0 +1,74 @@\n+\"\"\"Tests for app.db migrator.\n+\n+Covers:\n+  - fresh DB: migrate applies all, returns count.\n+  - re-run migrate: no-op on fully-applied state.\n+  - tampered migration (content hash mismatch): errors.\n+  - PRAGMA foreign_keys=ON is actually enforced by connect().\n+\"\"\"\n+\n+from __future__ import annotations\n+\n+import hashlib\n+import os\n+import sqlite3\n+from pathlib import Path\n+\n+import pytest\n+\n+from app import db as dbmod\n+\n+\n+@pytest.fixture\n+def fresh_db(tmp_path, monkeypatch):\n+    db_file = tmp_path / \"test.sqlite\"\n+    monkeypatch.setenv(\"DASHBOARD_KPI_DB\", str(db_file))\n+    yield db_file\n+\n+\n+def test_migrate_applies_all_on_fresh_db(fresh_db):\n+    applied = dbmod.migrate()\n+    assert applied >= 1, \"at least migration 001 should apply\"\n+    with dbmod.connect() as conn:\n+        rows = [r[\"version\"] for r in conn.execute(\"SELECT version FROM schema_migrations ORDER BY version\")]\n+    assert \"001\" in rows\n+\n+\n+def test_migrate_is_idempotent(fresh_db):\n+    first = dbmod.migrate()\n+    second = dbmod.migrate()\n+    assert second == 0, \"second migrate should be no-op\"\n+    assert first >= 1\n+\n+\n+def test_migrate_detects_tampered_migration(fresh_db):\n+    dbmod.migrate()\n+    # Simulate tamper: overwrite the stored sha256 with a bogus value.\n+    with dbmod.connect() as conn:\n+        conn.execute(\"UPDATE schema_migrations SET sha256='deadbeef' WHERE version='001'\")\n+    with pytest.raises(RuntimeError, match=\"different content\"):\n+        dbmod.migrate()\n+\n+\n+def test_foreign_keys_enforced(fresh_db):\n+    dbmod.migrate()\n+    with dbmod.connect() as conn:\n+        with pytest.raises(sqlite3.IntegrityError):\n+            conn.execute(\n+                \"INSERT INTO video_project_map(city_slug, video_id, confidence, mapping_source, active) \"\n+                \"VALUES ('ghost', 'nothere', 0.5, 'auto', 0)\"\n+            )\n+\n+\n+def test_wal_mode_enabled(fresh_db):\n+    dbmod.migrate()\n+    with dbmod.connect() as conn:\n+        mode = conn.execute(\"PRAGMA journal_mode\").fetchone()[0]\n+    assert mode.lower() == \"wal\"\n+\n+\n+def test_schema_migrations_table_shape(fresh_db):\n+    dbmod.migrate()\n+    with dbmod.connect() as conn:\n+        cols = {r[\"name\"] for r in conn.execute(\"PRAGMA table_info(schema_migrations)\")}\n+    assert cols == {\"version\", \"applied_at\", \"sha256\"}"}],"repository_full_name":"BlueRay2/history-production","comments":null,"author":{"login":"Evander","name":null,"email":null,"avatar_url":"https://avatars.githubusercontent.com/u/1937198?v=4","id":1937198},"committer":{"login":"Evander","name":null,"email":null,"avatar_url":"https://avatars.githubusercontent.com/u/1937198?v=4","id":1937198},"created_at":"2026-04-21T18:01:39Z","display_url":"https://github.com/BlueRay2/history-production/commit/e901155b5bb29851d2fcab9fbb86f869c2c756f7","display_title":"task-01(kpi): ADR-0001 + SQLite schema + migrator + tests"},"url":"https://github.com/BlueRay2/history-production/commit/e901155b5bb29851d2fcab9fbb86f869c2c756f7","title":"task-01(kpi): ADR-0001 + SQLite schema + migrator + tests\n\nImplements task-01-adr-and-schema per consensus ship verdict (Round 9).\n\n- docs/adr/0001-kpi-dashboard.md — ADR locking Flask+Jinja+HTMX+Chart.js+SQLite\n  stack + data model + sparse-metric discipline per consensus J-03 resolution.\n- db/migrations/001_init.sql — 8-table schema per research/codex.md §2:\n  schema_migrations, videos, projects, video_project_map, ingestion_runs,\n  channel_metric_snapshots, video_metric_snapshots, video_retention_points,\n  git_events. All append-only snapshots use (entity, metric, window, observed_on)\n  PK. 5 indexes for latest-snapshot reads.\n- app/db.py — connection helper with WAL + PRAGMA foreign_keys=ON. Raw-SQL\n  migrator with sha256 tamper detection. CLI: migrate | status | connect.\n- tests/test_migrations.py — 6 tests: fresh-apply, idempotent re-run, tampered\n  migration detection, FK enforcement, WAL mode, schema_migrations table shape.\n  All pass (pytest 8.4.2, Python 3.9.23 via practicum env).\n- pyproject.toml — project scaffolding + pytest dev dep; runtime deps deferred\n  to subsequent tasks per scope.\n\nStatus: task-01 pending → in-review-codex (r1).\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>","diff":"\n\n\n@@ -0,0 +1,134 @@\n+\"\"\"SQLite connection helper + raw-SQL migrator for KPI dashboard.\n+\n+Usage:\n+    python -m app.db migrate           # apply pending migrations\n+    python -m app.db status            # show current schema version\n+    python -m app.db connect           # return connection string for ad-hoc sqlite3 CLI\n+\"\"\"\n+\n+from __future__ import annotations\n+\n+import argparse\n+import hashlib\n+import os\n+import sqlite3\n+import sys\n+from contextlib import contextmanager\n+from datetime import datetime, timezone\n+from pathlib import Path\n+from typing import Iterator\n+\n+_DEFAULT_DB = \"/home/aiagent/assistant/state/dashboard-kpi.sqlite\"\n+_MIGRATIONS_DIR = Path(__file__).resolve().parent.parent / \"db\" / \"migrations\"\n+\n+\n+def db_path() -> str:\n+    return os.environ.get(\"DASHBOARD_KPI_DB\", _DEFAULT_DB)\n+\n+\n+@contextmanager\n+def connect() -> Iterator[sqlite3.Connection]:\n+    path = db_path()\n+    Path(path).parent.mkdir(parents=True, exist_ok=True)\n+    conn = sqlite3.connect(path, isolation_level=None)\n+    try:\n+        conn.execute(\"PRAGMA journal_mode=WAL\")\n+        conn.execute(\"PRAGMA foreign_keys=ON\")\n+        conn.row_factory = sqlite3.Row\n+        yield conn\n+    finally:\n+        conn.close()\n+\n+\n+def _sha256(text: str) -> str:\n+    return hashlib.sha256(text.encode(\"utf-8\")).hexdigest()\n+\n+\n+def _now_iso() -> str:\n+    return datetime.now(timezone.utc).strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n+\n+\n+def _ensure_migrations_table(conn: sqlite3.Connection) -> None:\n+    conn.execute(\n+        \"\"\"\n+        CREATE TABLE IF NOT EXISTS schema_migrations (\n+            version    TEXT PRIMARY KEY,\n+            applied_at TEXT NOT NULL,\n+            sha256     TEXT NOT NULL\n+        )\n+        \"\"\"\n+    )\n+\n+\n+def _applied_versions(conn: sqlite3.Connection) -> dict[str, str]:\n+    _ensure_migrations_table(conn)\n+    return {r[\"version\"]: r[\"sha256\"] for r in conn.execute(\"SELECT version, sha256 FROM schema_migrations\")}\n+\n+\n+def _discover_migrations(dir_: Path = _MIGRATIONS_DIR) -> list[tuple[str, Path, str]]:\n+    files = sorted(p for p in dir_.glob(\"*.sql\"))\n+    out: list[tuple[str, Path, str]] = []\n+    for p in files:\n+        version = p.stem.split(\"_\", 1)[0]\n+        out.append((version, p, p.read_text(encoding=\"utf-8\")))\n+    return out\n+\n+\n+def migrate() -> int:\n+    with connect() as conn:\n+        applied = _applied_versions(conn)\n+        migrations = _discover_migrations()\n+        pending = 0\n+        for version, path, sql in migrations:\n+            current_sha = _sha256(sql)\n+            if version in applied:\n+                if applied[version] != current_sha:\n+                    raise RuntimeError(\n+                        f\"migration {version} ({path.name}) already applied with different content \"\n+                        f\"(stored sha {applied[version]} vs current {current_sha}) — refusing to overwrite\"\n+                    )\n+                continue\n+            conn.executescript(sql)\n+            conn.execute(\n+                \"INSERT INTO schema_migrations(version, applied_at, sha256) VALUES (?,?,?)\",\n+                (version, _now_iso(), current_sha),\n+            )\n+            pending += 1\n+            print(f\"[migrate] applied {version} ({path.name})\", file=sys.stderr)\n+        if pending == 0:\n+            print(\"[migrate] nothing to apply\", file=sys.stderr)\n+        return pending\n+\n+\n+def status() -> None:\n+    with connect() as conn:\n+        applied = _applied_versions(conn)\n+        print(f\"db: {db_path()}\")\n+        print(f\"applied migrations: {len(applied)}\")\n+        for v in sorted(applied):\n+            print(f\"  {v}  sha={applied[v][:12]}\")\n+\n+\n+def main(argv: list[str] | None = None) -> int:\n+    parser = argparse.ArgumentParser(description=\"KPI dashboard DB helper\")\n+    sub = parser.add_subparsers(dest=\"cmd\", required=True)\n+    sub.add_parser(\"migrate\")\n+    sub.add_parser(\"status\")\n+    sub.add_parser(\"connect\").add_argument(\n+        \"--print-path\", action=\"store_true\", help=\"print db file path and exit\"\n+    )\n+    args = parser.parse_args(argv)\n+    if args.cmd == \"migrate\":\n+        migrate()\n+        return 0\n+    if args.cmd == \"status\":\n+        status()\n+        return 0\n+    if args.cmd == \"connect\":\n+        print(db_path())\n+        return 0\n+    return 2\n+\n+\n+if __name__ == \"__main__\":\n+    raise SystemExit(main())\n@@ -0,0 +1,133 @@\n+-- Migration 001: initial schema for KPI dashboard\n+-- Source: consensus-dashboard-kpi research/codex.md §2 + finding J-03 sparse-metric semantics\n+-- Ship: consensus-dashboard-kpi/verdict-round9.md\n+-- Applied via: python -m app.db migrate\n+\n+BEGIN;\n+\n+-- Schema versioning\n+CREATE TABLE IF NOT EXISTS schema_migrations (\n+    version    TEXT PRIMARY KEY,\n+    applied_at TEXT NOT NULL,\n+    sha256     TEXT NOT NULL\n+);\n+\n+-- YouTube video registry\n+CREATE TABLE videos (\n+    video_id      TEXT PRIMARY KEY,\n+    title         TEXT,\n+    published_at  TEXT,\n+    channel_id    TEXT,\n+    city_slug     TEXT,\n+    duration_s    INTEGER,\n+    created_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n+    updated_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\n+);\n+\n+-- Git-side project registry (one row per city folder in history-production)\n+CREATE TABLE projects (\n+    city_slug         TEXT PRIMARY KEY,\n+    first_commit_at   TEXT,\n+    canonical_path    TEXT,\n+    default_branch    TEXT,\n+    status            TEXT,\n+    created_at        TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\n+);\n+\n+-- City <-> video mapping with confidence + manual override\n+CREATE TABLE video_project_map (\n+    city_slug       TEXT NOT NULL,\n+    video_id        TEXT NOT NULL,\n+    confidence      REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\n+    mapping_source  TEXT NOT NULL CHECK (mapping_source IN ('auto','manual')),\n+    active          INTEGER NOT NULL DEFAULT 0 CHECK (active IN (0,1)),\n+    notes           TEXT,\n+    created_at      TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n+    PRIMARY KEY (city_slug, video_id),\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug),\n+    FOREIGN KEY (video_id)  REFERENCES videos(video_id)\n+);\n+\n+-- Every daily ingest run (for quota + failure audit)\n+CREATE TABLE ingestion_runs (\n+    run_id        TEXT PRIMARY KEY,\n+    source        TEXT NOT NULL,\n+    started_at    TEXT NOT NULL,\n+    finished_at   TEXT,\n+    status        TEXT NOT NULL,\n+    quota_units   INTEGER,\n+    error_text    TEXT\n+);\n+\n+-- Channel-level metric snapshots (append-only)\n+CREATE TABLE channel_metric_snapshots (\n+    metric_key    TEXT NOT NULL,\n+    grain         TEXT NOT NULL,\n+    window_start  TEXT NOT NULL,\n+    window_end    TEXT NOT NULL,\n+    observed_on   TEXT NOT NULL,\n+    value_num     REAL,\n+    run_id        TEXT NOT NULL,\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\n+    PRIMARY KEY (metric_key, grain, window_start, window_end, observed_on),\n+    FOREIGN KEY (run_id) REFERENCES ingestion_runs(run_id)\n+);\n+\n+-- Per-video metric snapshots (append-only)\n+CREATE TABLE video_metric_snapshots (\n+    video_id      TEXT NOT NULL,\n+    metric_key    TEXT NOT NULL,\n+    grain         TEXT NOT NULL,\n+    window_start  TEXT NOT NULL,\n+    window_end    TEXT NOT NULL,\n+    observed_on   TEXT NOT NULL,\n+    value_num     REAL,\n+    run_id        TEXT NOT NULL,\n+    preliminary   INTEGER NOT NULL DEFAULT 0 CHECK (preliminary IN (0,1)),\n+    PRIMARY KEY (video_id, metric_key, grain, window_start, window_end, observed_on),\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\n+);\n+\n+-- Per-video retention curve points\n+CREATE TABLE video_retention_points (\n+    video_id         TEXT NOT NULL,\n+    observed_on      TEXT NOT NULL,\n+    elapsed_seconds  REAL NOT NULL,\n+    retention_pct    REAL,\n+    run_id           TEXT NOT NULL,\n+    PRIMARY KEY (video_id, observed_on, elapsed_seconds),\n+    FOREIGN KEY (video_id) REFERENCES videos(video_id),\n+    FOREIGN KEY (run_id)   REFERENCES ingestion_runs(run_id)\n+);\n+\n+-- Git events (commits interpreted as KPI milestones)\n+CREATE TABLE git_events (\n+    commit_sha    TEXT PRIMARY KEY,\n+    city_slug     TEXT,\n+    branch_name   TEXT,\n+    committed_at  TEXT NOT NULL,\n+    event_type    TEXT NOT NULL,\n+    event_value   TEXT,\n+    payload_json  TEXT,\n+    confidence    REAL NOT NULL CHECK (confidence BETWEEN 0.0 AND 1.0),\n+    FOREIGN KEY (city_slug) REFERENCES projects(city_slug)\n+);\n+\n+-- Indexes for latest-snapshot reads\n+CREATE INDEX idx_channel_metric_latest\n+    ON channel_metric_snapshots(metric_key, window_end, observed_on DESC);\n+\n+CREATE INDEX idx_video_metric_latest\n+    ON video_metric_snapshots(video_id, metric_key, window_end, observed_on DESC);\n+\n+CREATE INDEX idx_git_events_city_type\n+    ON git_events(city_slug, event_type, committed_at);\n+\n+CREATE INDEX idx_vpm_video_active\n+    ON video_project_map(video_id, active);\n+\n+CREATE INDEX idx_vpm_city_active\n+    ON video_project_map(city_slug, active);\n+\n+COMMIT;\n@@ -0,0 +1,62 @@\n+# ADR-0001 — KPI Dashboard stack & architecture\n+\n+**Status:** Accepted\n+**Date:** 2026-04-21\n+**Context:** consensus-dashboard-kpi run (9 rounds, 2026-04-21), ship verdict round 9.\n+**Owner:** Ярослав (208368262); implementation lead: Claude.\n+\n+## Context\n+\n+Build a local-hosted KPI dashboard for YouTube channel \"Cities Evolution\" (UCjLrTC9jdfx6iI5w7SL8LHw, 44 subs, 24 videos). Daily 03:30 GMT+3 refresh via pure-Python YouTube API client + history-production git introspection. Weekly / Monthly tabs. Localhost-only MVP.\n+\n+## Decision\n+\n+### Stack\n+- **Backend framework:** Flask + Jinja (minimal, Python-native).\n+- **Frontend interactivity:** HTMX for server-fragment swaps; no SPA. Small amount of hand-rolled vanilla JS for local widget state — **no Alpine.js** (avoids micro-framework soup per consensus round 2).\n+- **Charts:** Chart.js via CDN.\n+- **Database:** SQLite with WAL journal mode + `PRAGMA foreign_keys=ON`.\n+- **DB migrations:** raw SQL files in `db/migrations/NNN_*.sql` applied by `app/db.py migrate` — no Alembic overhead at this scale.\n+- **YouTube ingest:** `google-api-python-client` + `google-auth-oauthlib` — **not** claude-headless+MCP (consensus round 1 finding F-08).\n+- **Python:** 3.11+.\n+- **Runtime:** home-server miniconda env `practicum` + flask dev server under systemd user unit.\n+\n+### Data model (see `db/migrations/001_init.sql`)\n+- Append-only snapshot pattern with `(entity, metric, window, observed_on)` PK — no destructive updates.\n+- First-class `video_project_map` table with `confidence` + manual-override support.\n+- `git_events` table records heuristic parse output with confidence scores.\n+\n+### Deploy layout\n+- Code lives in this repo (`history-production`) under branch `kpi`.\n+- Install script creates symlink `/home/aiagent/assistant/deploys/kpi-dashboard → /home/aiagent/assistant/git/history-production`.\n+- Runtime state (DB, logs) under `/home/aiagent/assistant/state/` and `/home/aiagent/assistant/logs/`.\n+\n+### Metric handling (sparse-data discipline)\n+- Unavailable metrics return NULL in SQL, never 0 (consensus finding J-03).\n+- Repository API `value_with_reason() -> (value, reason)` where reason ∈ {`ok`, `below_privacy_floor`, `channel_too_new`, `no_data_pulled`}.\n+- UI renders each reason distinctly (`N/A` with tooltip vs raw value).\n+\n+## Consequences\n+\n+### Positive\n+- Tests are easy: raw SQL + std-lib sqlite3 has zero ORM magic.\n+- Deploy is a single symlink + one systemd unit.\n+- Future LAN / auth migration to FastAPI would touch only `app/main.py` — ingest/repo/views stay portable.\n+\n+### Negative / accepted trade-offs\n+- Flask dev server is not production-grade — acceptable for localhost single-user MVP; gunicorn/uvicorn migration deferred until LAN access is scoped.\n+- Raw SQL migrations lack the diff tooling of Alembic — acceptable at expected schema volume (≤20 migrations before major refactor).\n+\n+## Rejected alternatives\n+\n+- **Streamlit:** heavy rerun model; poor fit for 10-15 charts; weak auth story.\n+- **FastAPI+HTMX+Alpine+Chart.js:** over-engineered for this MVP; ~2× build time; framework soup risk.\n+- **Grafana + SQLite:** wrong fit for heuristic joins + mapping overrides + write-back exception workflow.\n+- **Evidence.dev:** static-site builder; no live mapping-approval workflow.\n+- **Datasette:** explorer UI, not a curated dashboard; read-only by design.\n+\n+## References\n+\n+- Consensus run: `/home/aiagent/assistant/git/consensus-dashboard-kpi/`\n+- Authoritative verdict: highest-numbered `verdict-roundN.md` in that directory (currently `verdict-round9.md`).\n+- Task process: [../tz/dashboard-kpi/process.md](../tz/dashboard-kpi/process.md)\n@@ -17,7 +17,7 @@ Full consensus artefacts (research, debates, findings register, verdicts) are in\n \n | ID | File | Scope | Status | Codex review | Gemini review |\n |---|---|---|---|---|---|\n-| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `pending` | — | — |\n+| 01 | [task-01-adr-and-schema.md](task-01-adr-and-schema.md) | Stack ADR (Flask+Jinja+HTMX+Chart.js+SQLite), DB schema, raw SQL migrations, `schema_migrations` table | `in-review-codex (r1)` | pending | — |\n | 02 | [task-02-youtube-api-client.md](task-02-youtube-api-client.md) | OAuth install-flow, refresh-token cache in `/home/aiagent/.config/youtube-api/.env` (600), typed client wrapper, vcrpy cassette fixtures | `pending` | — | — |\n | 03 | [task-03-append-snapshot-ingest.md](task-03-append-snapshot-ingest.md) | Ingestion runs table, rolling 45-d backfill, append-only writes with `observed_on`, preliminary-flag overwrite logic, first-run 45-d backfill script | `pending` | — | — |\n | 04 | [task-04-history-git-parser.md](task-04-history-git-parser.md) | `ingest/history_git.py`, heuristic commit scoring (phase-\\d+ / script / final / lock patterns), confidence + evidence columns, golden git fixtures | `pending` | — | — |\n@@ -0,0 +1,29 @@\n+[project]\n+name = \"kpi-dashboard\"\n+version = \"0.1.0\"\n+description = \"Local-hosted KPI dashboard for YouTube channel Cities Evolution.\"\n+requires-python = \">=3.11\"\n+dependencies = [\n+    # Runtime dependencies land here in subsequent tasks:\n+    #   task-02: google-api-python-client, google-auth-oauthlib, python-dotenv\n+    #   task-06: flask, jinja2\n+    # task-01 introduces only the stdlib-backed db layer + test harness.\n+]\n+\n+[project.optional-dependencies]\n+dev = [\n+    \"pytest>=8.0,<9\",\n+    \"pytest-cov>=5.0,<6\",\n+]\n+\n+[tool.pytest.ini_options]\n+testpaths = [\"tests\"]\n+pythonpath = [\".\"]\n+addopts = \"-ra\"\n+\n+[build-system]\n+requires = [\"setuptools>=68\"]\n+build-backend = \"setuptools.build_meta\"\n+\n+[tool.setuptools]\n+packages = [\"app\"]\n\n\n\n@@ -0,0 +1,74 @@\n+\"\"\"Tests for app.db migrator.\n+\n+Covers:\n+  - fresh DB: migrate applies all, returns count.\n+  - re-run migrate: no-op on fully-applied state.\n+  - tampered migration (content hash mismatch): errors.\n+  - PRAGMA foreign_keys=ON is actually enforced by connect().\n+\"\"\"\n+\n+from __future__ import annotations\n+\n+import hashlib\n+import os\n+import sqlite3\n+from pathlib import Path\n+\n+import pytest\n+\n+from app import db as dbmod\n+\n+\n+@pytest.fixture\n+def fresh_db(tmp_path, monkeypatch):\n+    db_file = tmp_path / \"test.sqlite\"\n+    monkeypatch.setenv(\"DASHBOARD_KPI_DB\", str(db_file))\n+    yield db_file\n+\n+\n+def test_migrate_applies_all_on_fresh_db(fresh_db):\n+    applied = dbmod.migrate()\n+    assert applied >= 1, \"at least migration 001 should apply\"\n+    with dbmod.connect() as conn:\n+        rows = [r[\"version\"] for r in conn.execute(\"SELECT version FROM schema_migrations ORDER BY version\")]\n+    assert \"001\" in rows\n+\n+\n+def test_migrate_is_idempotent(fresh_db):\n+    first = dbmod.migrate()\n+    second = dbmod.migrate()\n+    assert second == 0, \"second migrate should be no-op\"\n+    assert first >= 1\n+\n+\n+def test_migrate_detects_tampered_migration(fresh_db):\n+    dbmod.migrate()\n+    # Simulate tamper: overwrite the stored sha256 with a bogus value.\n+    with dbmod.connect() as conn:\n+        conn.execute(\"UPDATE schema_migrations SET sha256='deadbeef' WHERE version='001'\")\n+    with pytest.raises(RuntimeError, match=\"different content\"):\n+        dbmod.migrate()\n+\n+\n+def test_foreign_keys_enforced(fresh_db):\n+    dbmod.migrate()\n+    with dbmod.connect() as conn:\n+        with pytest.raises(sqlite3.IntegrityError):\n+            conn.execute(\n+                \"INSERT INTO video_project_map(city_slug, video_id, confidence, mapping_source, active) \"\n+                \"VALUES ('ghost', 'nothere', 0.5, 'auto', 0)\"\n+            )\n+\n+\n+def test_wal_mode_enabled(fresh_db):\n+    dbmod.migrate()\n+    with dbmod.connect() as conn:\n+        mode = conn.execute(\"PRAGMA journal_mode\").fetchone()[0]\n+    assert mode.lower() == \"wal\"\n+\n+\n+def test_schema_migrations_table_shape(fresh_db):\n+    dbmod.migrate()\n+    with dbmod.connect() as conn:\n+        cols = {r[\"name\"] for r in conn.execute(\"PRAGMA table_info(schema_migrations)\")}\n+    assert cols == {\"version\", \"applied_at\", \"sha256\"}","display_url":"https://github.com/BlueRay2/history-production/commit/e901155b5bb29851d2fcab9fbb86f869c2c756f7","display_title":"task-01(kpi): ADR-0001 + SQLite schema + migrator + tests\n\nImplements task-01-adr-and-schema per consensus ship verdict (Round 9).\n\n- docs/adr/0001-kpi-dashboard.md — ADR locking Flask+Jinja+HTMX+Chart.js+SQLite\n  stack + data model + sparse-metric discipline per consensus J-03 resolution.\n- db/migrations/001_init.sql — 8-table schema per research/codex.md §2:\n  schema_migrations, videos, projects, video_project_map, ingestion_runs,\n  channel_metric_snapshots, video_metric_snapshots, video_retention_points,\n  git_events. All append-only snapshots use (entity, metric, window, observed_on)\n  PK. 5 indexes for latest-snapshot reads.\n- app/db.py — connection helper with WAL + PRAGMA foreign_keys=ON. Raw-SQL\n  migrator with sha256 tamper detection. CLI: migrate | status | connect.\n- tests/test_migrations.py — 6 tests: fresh-apply, idempotent re-run, tampered\n  migration detection, FK enforcement, WAL mode, schema_migrations table shape.\n  All pass (pytest 8.4.2, Python 3.9.23 via practicum env).\n- pyproject.toml — project scaffolding + pytest dev dep; runtime deps deferred\n  to subsequent tasks per scope.\n\nStatus: task-01 pending → in-review-codex (r1).\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>"}},"error":null,"status":"completed"}}
