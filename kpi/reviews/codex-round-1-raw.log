s":"added","additions":0,"deletions":0,"changes":0,"previous_filename":null},{"filename":"app/db.py","status":"added","additions":134,"deletions":0,"changes":134,"previous_filename":null},{"filename":"db/migrations/001_init.sql","status":"added","additions":133,"deletions":0,"changes":133,"previous_filename":null},{"filename":"docs/adr/0001-kpi-dashboard.md","status":"added","additions":62,"deletions":0,"changes":62,"previous_filename":null},{"filename":"docs/tz/dashboard-kpi/README.md","status":"modified","additions":1,"deletions":1,"changes":2,"previous_filename":null},{"filename":"pyproject.toml","status":"added","additions":29,"deletions":0,"changes":29,"previous_filename":null},{"filename":"tests/__init__.py","status":"added","additions":0,"deletions":0,"changes":0,"previous_filename":null},{"filename":"tests/test_migrations.py","status":"added","additions":74,"deletions":0,"changes":74,"previous_filename":null}]}},"error":null,"status":"completed"}}
